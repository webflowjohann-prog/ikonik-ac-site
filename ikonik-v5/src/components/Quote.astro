---
// Quote.astro — citation centrée avec 2 dots orange au-dessus
interface Props {
  text: string;
  author?: string;
}
const { text, author } = Astro.props;
---

<div class="quote-section rv">
  <div class="quote-dots">
    <span class="quote-dot"></span>
    <span class="quote-dot"></span>
  </div>
  <blockquote class="quote-text">{text}</blockquote>
  {author && <p class="quote-author">{author}</p>}
</div>

<style>
  .quote-author {
    font-size: 1.2rem;
    font-weight: 450;
    letter-spacing: .16em;
    text-transform: uppercase;
    margin-top: 2rem;
    color: var(--gray);
  }
</style>
