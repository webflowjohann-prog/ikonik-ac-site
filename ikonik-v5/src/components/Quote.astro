---
// Quote.astro — citation centrée, 2 dots orange, sans-serif weight 300 (exact Warwick)
interface Props {
  text: string;
  author?: string;
}
const { text, author } = Astro.props;
---

<div class="quote-section rv">
  <div class="quote-section__inner">
    <div class="quote-dots" aria-hidden="true">
      <span class="quote-dot"></span>
      <span class="quote-dot"></span>
    </div>
    <blockquote class="quote-text">{text}</blockquote>
    {author && <p class="quote-author">{author}</p>}
  </div>
</div>
