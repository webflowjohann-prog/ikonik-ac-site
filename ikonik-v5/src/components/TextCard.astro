---
// TextCard.astro — card 3 colonnes avec gradient blanc
interface Props {
  label: string;
  title: string;
  description: string;
  imageSrc?: string;
  videoSrc?: string;
}
const { label, title, description, imageSrc, videoSrc } = Astro.props;
---

<div class="tc rv">
  <span class="tc__label">{label}</span>
  <h3 class="tc__h">{title}</h3>
  <p style="font-size:1.5rem;font-weight:300;letter-spacing:.06em;line-height:2.4rem;color:var(--gray)">{description}</p>
  {(imageSrc || videoSrc) && (
    <div class="tc__img">
      {videoSrc
        ? <video autoplay muted playsinline loop src={videoSrc}></video>
        : <img src={imageSrc} alt={title} loading="lazy" />
      }
    </div>
  )}
</div>
