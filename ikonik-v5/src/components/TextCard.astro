---
// TextCard.astro — card 3 colonnes (exact Warwick .text-card)
interface Props {
  label: string;
  description: string;
  imageSrc?: string;
  videoSrc?: string;
}
const { label, description, imageSrc, videoSrc } = Astro.props;
---

<div class="tc rv">
  <div>
    <span class="tc__label">{label}</span>
    <p class="tc__h">{description}</p>
  </div>
  {(imageSrc || videoSrc) && (
    <div class="tc__img">
      {videoSrc
        ? <video autoplay muted playsinline loop src={videoSrc}></video>
        : <img src={imageSrc} alt={label} loading="lazy" />
      }
    </div>
  )}
</div>
