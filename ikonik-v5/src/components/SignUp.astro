---
// SignUp.astro — card blanche arrondie avec formulaire newsletter Supabase
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Restez dans la boucle',
  description = 'Soyez les premiers informés de nos nouveaux projets, services et offres.'
} = Astro.props;
---

<div class="su rv">
  <div style="max-width:340px;margin-bottom:2rem">
    <h2 class="su__t">{title}</h2>
    <p class="su__d">{description}</p>
  </div>
  <form class="su__form" id="signupForm">
    <div class="su__fields">
      <div class="su__f">
        <input class="su__inp" type="text" placeholder=" " id="fn" name="firstName" required>
        <label class="su__lbl" for="fn">Prénom</label>
      </div>
      <div class="su__f">
        <input class="su__inp" type="text" placeholder=" " id="ln" name="lastName" required>
        <label class="su__lbl" for="ln">Nom</label>
      </div>
    </div>
    <div class="su__f">
      <input class="su__inp" type="email" placeholder=" " id="em" name="email" required>
      <label class="su__lbl" for="em">Adresse email</label>
    </div>
    <div style="display:flex;justify-content:flex-end;margin-top:1rem">
      <button class="button" type="submit" id="signupBtn">
        <span class="btn btn--pri" style="height:5.2rem">
          <span class="bt bt--in">S'inscrire</span>
          <span class="bt bt--out" aria-hidden="true">S'inscrire</span>
        </span>
      </button>
    </div>
    <p id="signupMsg" style="display:none;font-size:1.4rem;text-align:center;margin-top:1rem"></p>
  </form>
</div>

<style is:global>
  .su__form { display: flex; flex-direction: column; gap: 1.2rem; width: 100%; max-width: 500px; }
  .su__fields { display: flex; flex-direction: column; gap: 1.2rem; }
  @media (min-width: 768px) { .su__fields { flex-direction: row; gap: 1.2rem; } }
</style>

<script is:inline>
  var SB_URL='https://kgfolduvslsytbekbjvf.supabase.co';
  var SB_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtnZm9sZHV2c2xzeXRiZWtianZmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUxNDU3MDcsImV4cCI6MjA5MDcyMTcwN30.4jZ9fMfSinEc1CE3s6LuR4q_WNeisEdtyBM5XQ2uMJg';

  var signupForm = document.getElementById('signupForm');
  if (signupForm) {
    signupForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      var msg = document.getElementById('signupMsg');
      var prenom = document.getElementById('fn').value;
      var email = document.getElementById('em').value;

      try {
        var r = await fetch(SB_URL + '/rest/v1/newsletter_subscribers', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SB_KEY,
            'Authorization': 'Bearer ' + SB_KEY,
            'Prefer': 'return=minimal'
          },
          body: JSON.stringify({
            email: email,
            prenom: prenom,
            source: 'site-homepage',
            statut: 'actif'
          })
        });

        if (r.ok) {
          if (msg) { msg.style.display = 'block'; msg.style.color = '#3FB950'; msg.textContent = 'Merci — vous etes inscrit !'; }
          signupForm.reset();
        } else {
          var err = await r.text();
          if (err.indexOf('duplicate') > -1 || err.indexOf('unique') > -1) {
            if (msg) { msg.style.display = 'block'; msg.style.color = '#b8963e'; msg.textContent = 'Vous etes deja inscrit.'; }
          } else {
            throw new Error(err);
          }
        }
      } catch(err) {
        if (msg) { msg.style.display = 'block'; msg.style.color = '#F85149'; msg.textContent = 'Une erreur est survenue. Reessayez.'; }
      }
    });
  }
</script>
