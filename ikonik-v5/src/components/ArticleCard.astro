---
// ArticleCard.astro — card article avec accent couleur fin par catégorie
interface Props {
  tag?: string;
  title: string;
  excerpt?: string;
  href: string;
  imageSrc?: string;
  color?: string;
  date?: string;
}
const { tag, title, excerpt, href, imageSrc, color, date } = Astro.props;
---

<a class="article-card rv" href={href} style={color ? `--card-accent:${color}` : ''}>
  {color && <div class="article-card__accent"></div>}
  {imageSrc && (
    <div class="article-card__img">
      <img src={imageSrc} alt={title} loading="lazy" />
    </div>
  )}
  <div class="article-card__body">
    {tag && <span class="article-card__tag" style={color ? `color:${color}` : ''}>{tag}</span>}
    <h3 class="article-card__title">{title}</h3>
    {excerpt && <p class="article-card__excerpt">{excerpt}</p>}
    {date && <p class="article-card__date">{date}</p>}
  </div>
</a>

<style>
  .article-card__accent {
    background-color: var(--card-accent, var(--accent));
    border-radius: 20px 20px 0 0;
    height: 4px;
    width: 100%;
  }
</style>
