---
// ArticleCard.astro — card article avec image hover
interface Props {
  tag?: string;
  title: string;
  excerpt?: string;
  href: string;
  imageSrc?: string;
  date?: string;
}
const { tag, title, excerpt, href, imageSrc, date } = Astro.props;
---

<a class="article-card rv" href={href}>
  {imageSrc && (
    <div class="article-card__img">
      <img src={imageSrc} alt={title} loading="lazy" />
    </div>
  )}
  <div class="article-card__body">
    {tag && <span class="article-card__tag">{tag}</span>}
    <h3 class="article-card__title">{title}</h3>
    {excerpt && <p class="article-card__excerpt">{excerpt}</p>}
    {date && <p style="font-size:1.2rem;font-weight:450;letter-spacing:.1em;text-transform:uppercase;color:var(--gray);margin-top:auto">{date}</p>}
  </div>
</a>
