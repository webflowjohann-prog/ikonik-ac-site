---
// Header.astro — fixe, collapse > 200px scroll down, peek scroll up
// Logo : LOGO_IKONIK_blanc.webp
---

<header class="header" id="header">
  <div class="container">
    <div class="header__inner">

      <a class="header__logo" href="/" aria-label="IKONIK">
        <img
          src="/LOGO_IKONIK_blanc.webp"
          alt="IKONIK"
          class="header__logo-img"
          width="160"
          height="32"
        />
      </a>

      <nav class="dnav" aria-label="Navigation principale">
        <menu class="dnav__menu">
          <li><a class="dnav__link" href="/">Accueil</a></li>
          <li><a class="dnav__link" href="/creatif">Créatif</a></li>
          <li><a class="dnav__link" href="/tech">Tech</a></li>
          <li><a class="dnav__link" href="/studio">Studio</a></li>
          <li><a class="dnav__link" href="/blog">Journal</a></li>
          <li><a class="dnav__link" href="/contact">Contact</a></li>
        </menu>
      </nav>

      <button class="burger" aria-label="Ouvrir le menu" id="burgerBtn">
        <svg fill="none" viewBox="0 0 44 44" width="44" height="44" aria-hidden="true" id="burgerIcon">
          <line x1="10" y1="16" x2="34" y2="16" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="10" y1="28" x2="34" y2="28" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

    </div>
  </div>
</header>

<!-- Mobile menu overlay -->
<div class="mobile-menu" id="mobileMenu">
  <a href="/" onclick="closeMobile()">Accueil</a>
  <a href="/creatif" onclick="closeMobile()">Créatif</a>
  <a href="/tech" onclick="closeMobile()">Tech</a>
  <a href="/studio" onclick="closeMobile()">Studio</a>
  <a href="/blog" onclick="closeMobile()">Journal</a>
  <a href="/contact" onclick="closeMobile()">Contact</a>
</div>


<script is:inline>
  // Mobile menu toggle
  var menuOpen = false;
  var burgerBtn = document.getElementById('burgerBtn');
  var mobileMenu = document.getElementById('mobileMenu');
  if (burgerBtn) {
    burgerBtn.addEventListener('click', function() {
      menuOpen = !menuOpen;
      mobileMenu.classList.toggle('open', menuOpen);
      document.body.style.overflow = menuOpen ? 'hidden' : '';
      // Change burger to X
      var icon = document.getElementById('burgerIcon');
      if (menuOpen) {
        icon.innerHTML = '<line x1="12" y1="12" x2="32" y2="32" stroke="white" stroke-width="1.5" stroke-linecap="round"/><line x1="32" y1="12" x2="12" y2="32" stroke="white" stroke-width="1.5" stroke-linecap="round"/>';
      } else {
        icon.innerHTML = '<line x1="10" y1="16" x2="34" y2="16" stroke="white" stroke-width="1.5" stroke-linecap="round"/><line x1="10" y1="28" x2="34" y2="28" stroke="white" stroke-width="1.5" stroke-linecap="round"/>';
      }
    });
  }
  function closeMobile() {
    menuOpen = false;
    if (mobileMenu) mobileMenu.classList.remove('open');
    document.body.style.overflow = '';
  }
</script>


<script>
  const header = document.getElementById('header');
  let lastY = window.scrollY;
  let ticking = false;
  const THRESHOLD = 200;

  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        const y = window.scrollY;

        if (y > lastY && y > THRESHOLD) {
          // Scroll DOWN + dépassé le seuil → collapse
          header?.classList.add('header--collapsed');
          header?.classList.remove('header--peeked');
        } else if (y < lastY && y > THRESHOLD) {
          // Scroll UP (toujours en bas de page) → peek avec fond dark
          header?.classList.remove('header--collapsed');
          header?.classList.add('header--peeked');
        } else if (y <= THRESHOLD) {
          // Remonté en haut → reset
          header?.classList.remove('header--collapsed', 'header--peeked');
        }

        lastY = y;
        ticking = false;
      });
      ticking = true;
    }
  });
</script>
