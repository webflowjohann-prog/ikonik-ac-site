---
// Header.astro — exact Warwick: fixe, collapse au scroll down > 200px, peek au scroll up
---

<header class="header" id="header">
  <div class="container">
    <div class="header__inner">

      <a class="header__logo" href="/" aria-label="IKONIK">
        <span class="header__logo-text">IKONIK</span>
      </a>

      <nav class="dnav">
        <menu class="dnav__menu">
          <li><a class="dnav__link" href="/creatif">Créatif</a></li>
          <li><a class="dnav__link" href="/tech">Tech</a></li>
          <li><a class="dnav__link" href="/studio">Studio</a></li>
          <li><a class="dnav__link" href="/blog">Journal</a></li>
          <li><a class="dnav__link" href="/contact">Contact</a></li>
        </menu>
      </nav>

      <button class="burger" aria-label="Menu" id="burgerBtn">
        <svg fill="none" viewBox="0 0 44 44">
          <line x1="10" y1="16" x2="34" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="10" y1="28" x2="34" y2="28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

    </div>
  </div>
</header>

<style>
  .header__logo-text {
    color: var(--white);
    font-family: var(--sans);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: .3em;
    text-transform: uppercase;
    animation: fadeIn 1.5s ease-in-out forwards;
    animation-delay: 1s;
    opacity: 0;
  }
  .burger {
    color: var(--white);
  }
  :global(.header--collapsed) .header__logo-text {
    color: var(--white);
  }
  :global(.header--collapsed) .burger {
    color: var(--white);
  }
</style>

<script>
  // Exact Warwick scroll behavior: collapse at 200px, peek on scroll up
  const header = document.getElementById('header');
  let lastY = 0;
  let collapsed = false;

  window.addEventListener('scroll', () => {
    const y = window.pageYOffset;
    if (y > 200) {
      if (!collapsed) {
        header?.classList.add('header--collapsed');
        collapsed = true;
      }
      if (y < lastY - 5) {
        header?.classList.add('header--peeked');
      } else if (y > lastY + 5) {
        header?.classList.remove('header--peeked');
      }
    } else {
      header?.classList.remove('header--collapsed', 'header--peeked');
      collapsed = false;
    }
    lastY = y;
  });
</script>
