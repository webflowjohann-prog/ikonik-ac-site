---
// ProductGate.astro — layout 2 colonnes alterné (vidéo arrondie + content-block)
// Utilisé pour les 2 portes Créatif / Tech
interface Props {
  tag: string;
  title: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
  videoSrc: string;
  accentType?: 'dot' | 'chevron';  // dot = Créatif, chevron = Tech
  reversed?: boolean;
  theme?: 'light' | 'dark';
}
const {
  tag, title, description, ctaLabel, ctaHref,
  videoSrc, accentType = 'dot', reversed = false, theme = 'light'
} = Astro.props;

const cbClass = theme === 'dark' ? 'cb cb--d' : 'cb cb--l';
const btnClass = theme === 'dark' ? 'btn btn--sec' : 'btn btn--pri';
const strokeColor = theme === 'dark' ? '#FFFFFF' : '#222931';
---

<div class={`grid grid--gap-lg rv${reversed ? ' grid--reversed' : ''}`}>
  {reversed ? (
    <>
      <div class={cbClass}>
        <div class="cb__h">
          <span class="cb__tag">{tag}</span>
          <h2>
            <span class="h-line">
              <span>{title}</span>
              {accentType === 'dot' ? (
                <svg fill="none" viewBox="0 0 200 11" width="160" height="11">
                  <path d={`M177 5.5H0`} stroke={strokeColor}></path>
                  <circle cx="194.5" cy="5.5" r="5.5" fill="#E9540D"></circle>
                </svg>
              ) : (
                <svg fill="none" viewBox="0 0 200 12" width="160" height="12">
                  <path d="M179 6H0" stroke={strokeColor}></path>
                  <path d="m191 0 8.195 6L191 12V0Z" fill="#E9540D"></path>
                </svg>
              )}
            </span>
          </h2>
        </div>
        <div class="cb__wrap">
          <div class="cb__t">{description}</div>
          <div class="cb__ctas">
            <a class="button" href={ctaHref}>
              <span class={`btn ${btnClass.split(' ')[1]}`}>
                <span class="bt bt--in">{ctaLabel}</span>
                <span class="bt bt--out" aria-hidden="true">{ctaLabel}</span>
              </span>
            </a>
          </div>
        </div>
      </div>
      <div class="new-card">
        <video autoplay muted playsinline loop src={videoSrc} class="new-card__video"></video>
      </div>
    </>
  ) : (
    <>
      <div class="new-card">
        <video autoplay muted playsinline loop src={videoSrc} class="new-card__video"></video>
      </div>
      <div class={cbClass}>
        <div class="cb__h">
          <span class="cb__tag">{tag}</span>
          <h2>
            <span class="h-line">
              <span>{title}</span>
              {accentType === 'dot' ? (
                <svg fill="none" viewBox="0 0 200 11" width="160" height="11">
                  <path d="M177 5.5H0" stroke={strokeColor}></path>
                  <circle cx="194.5" cy="5.5" r="5.5" fill="#E9540D"></circle>
                </svg>
              ) : (
                <svg fill="none" viewBox="0 0 200 12" width="160" height="12">
                  <path d="M179 6H0" stroke={strokeColor}></path>
                  <path d="m191 0 8.195 6L191 12V0Z" fill="#E9540D"></path>
                </svg>
              )}
            </span>
          </h2>
        </div>
        <div class="cb__wrap">
          <div class="cb__t">{description}</div>
          <div class="cb__ctas">
            <a class="button" href={ctaHref}>
              <span class={`btn ${btnClass.split(' ')[1]}`}>
                <span class="bt bt--in">{ctaLabel}</span>
                <span class="bt bt--out" aria-hidden="true">{ctaLabel}</span>
              </span>
            </a>
          </div>
        </div>
      </div>
    </>
  )}
</div>

<style>
  .grid--reversed {
    direction: rtl;
  }
  .grid--reversed > * {
    direction: ltr;
  }
</style>
