---
// HeroVideo.astro — hero vidéo plein écran. Titre statique HTML + animations CSS.
// Ligne 1 : "Make" (serif italic) + "It" (sans uppercase) sur la même ligne
// Ligne 2 : Logo IKONIK blanc en image
// Ligne 3 : Sous-titre fade-in
interface Props {
  videoSrc: string;
  subtitle?: string;
}
const { videoSrc, subtitle } = Astro.props;
---

<section class="home-hero" id="hero">

  <div class="home-hero__background">
    <video autoplay muted playsinline loop src={videoSrc} aria-hidden="true"></video>
  </div>

  <div class="home-hero__inner">

    <!-- Ligne 1 : Make It — flex row, baseline alignés -->
    <div class="home-hero__line1">
      <em class="home-hero__make">Make</em>
      <span class="home-hero__it">It</span>
    </div>

    <!-- Ligne 2 : Logo IKONIK image -->
    <div class="home-hero__line2">
      <img
        src="/images/LOGO_IKONIK_blanc.webp"
        alt="IKONIK"
        class="home-hero__logo"
      />
    </div>

    <!-- Ligne 3 : Sous-titre -->
    {subtitle && (
      <p class="home-hero__subtitle">{subtitle}</p>
    )}

  </div>

  <svg fill="none" viewBox="0 0 12 34" class="home-hero__scroll-indicator" aria-hidden="true">
    <path d="M12 0 6 8.195 0 0h12Z" fill="#e9540d"/>
    <path d="m12 25-6 8.195L0 25h12Z" fill="#fff"/>
  </svg>

</section>

<style>
  .home-hero {
    height: 100vh;
    overflow: hidden;
    position: relative;
    width: 100%;
  }
  /* Overlay gradient — haut uniquement pour lisibilité du texte */
  .home-hero::after {
    background: linear-gradient(180deg, rgba(21,28,36,.5) 0%, rgba(21,28,36,.2) 40%, transparent 70%);
    content: "";
    inset: 0;
    position: absolute;
    z-index: 4;
  }

  /* Vidéo : 115% hauteur, centrée — exact Warwick */
  .home-hero__background {
    height: 115%;
    left: 50%;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -57%);
    width: 100%;
    z-index: 2;
  }
  .home-hero__background video {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  /* Inner centré */
  .home-hero__inner {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    height: 100%;
    justify-content: center;
    left: 0;
    position: absolute;
    top: 0;
    width: 100%;
    z-index: 5;
  }

  /* Ligne 1 : "Make It" sur la même ligne */
  .home-hero__line1 {
    align-items: baseline;
    animation: moveUpAndFadeIn 1s ease-in-out forwards;
    animation-delay: .3s;
    display: flex;
    gap: 2rem;
    justify-content: center;
    opacity: 0;
  }
  .home-hero__make {
    color: var(--white);
    font-family: var(--serif);
    font-size: 7.2rem;
    font-style: italic;
    font-weight: 900;
    letter-spacing: .02em;
    line-height: 1;
    text-transform: none;
  }
  @media (min-width: 768px) { .home-hero__make { font-size: 13rem; } }
  @media (min-width: 992px)  { .home-hero__make { font-size: 16rem; } }

  .home-hero__it {
    color: var(--white);
    font-family: var(--sans);
    font-size: 5.6rem;
    font-weight: 600;
    letter-spacing: .06em;
    line-height: 1;
    text-transform: uppercase;
  }
  @media (min-width: 768px) { .home-hero__it { font-size: 10.4rem; } }
  @media (min-width: 992px)  { .home-hero__it { font-size: 12rem; } }

  /* Ligne 2 : Logo image */
  .home-hero__line2 {
    animation: moveUpAndFadeIn 1s ease-in-out forwards;
    animation-delay: .7s;
    opacity: 0;
  }
  .home-hero__logo {
    display: block;
    height: 6rem;
    max-width: 90vw;
    object-fit: contain;
    width: auto;
  }
  @media (min-width: 768px) { .home-hero__logo { height: 9rem; } }
  @media (min-width: 992px)  { .home-hero__logo { height: 12rem; } }

  /* Ligne 3 : Sous-titre */
  .home-hero__subtitle {
    animation: moveUpAndFadeIn 1s ease-in-out forwards;
    animation-delay: 1.2s;
    color: var(--white);
    font-family: var(--sans);
    font-size: 2.4rem;
    font-weight: 450;
    letter-spacing: .06em;
    line-height: 3.6rem;
    margin: .8rem 0 0;
    opacity: 0;
    text-align: center;
  }
  @media (min-width: 768px) { .home-hero__subtitle { font-size: 2.8rem; line-height: 4rem; } }
  @media (min-width: 992px)  { .home-hero__subtitle { font-size: 3.2rem; line-height: 4.4rem; } }

  /* Scroll indicator */
  .home-hero__scroll-indicator {
    animation: fadeIn 2s ease-in-out forwards;
    animation-delay: 2.5s;
    bottom: 10%;
    opacity: 0;
    position: absolute;
    right: 50%;
    transform: translateX(-50%);
    width: 10px;
    z-index: 6;
  }
  @media (min-width: 992px) { .home-hero__scroll-indicator { right: 4rem; transform: none; } }
</style>
