---
// HeroVideo.astro — hero vidéo plein écran. CSS dans global.css.
interface Props {
  videoSrc: string;
  titleLines: string[];
  subtitle?: string;
}
const { videoSrc, titleLines, subtitle } = Astro.props;
---

<section class="home-hero" id="hero">

  <div class="home-hero__background">
    <video autoplay muted playsinline loop class="home-hero__video" src={videoSrc} aria-hidden="true"></video>
  </div>

  <div class="home-hero__overlay" aria-hidden="true"></div>

  <div class="home-hero__inner">
    <div class="container">
      <h1 class="home-hero__title">
        {titleLines.map((line, i) => (
          <span class="hero-title-line" style={`animation-delay:${0.2 + i * 0.2}s`}>{line}</span>
        ))}
      </h1>
      {subtitle && <p class="home-hero__subtitle">{subtitle}</p>}
    </div>
  </div>

  <svg fill="none" viewBox="0 0 12 34" class="home-hero__scroll-indicator" aria-hidden="true">
    <path d="M12 0 6 8.195 0 0h12Z" fill="#e9540d"/>
    <path d="m12 25-6 8.195L0 25h12Z" fill="#fff"/>
  </svg>

</section>
