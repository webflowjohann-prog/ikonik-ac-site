---
// IkoAssistant.astro — Widget chat IA IKONIK (IKO)
---

<!-- Chat toggle button -->
<button id="iko-toggle" class="iko-toggle" aria-label="Assistant IKONIK">
  <span class="iko-toggle__icon" id="iko-icon-chat">
    <svg width="24" height="24" fill="none" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 5.8 2 10.5c0 2.7 1.5 5 3.8 6.5L4 22l4.8-2.5c1 .3 2.1.5 3.2.5 5.52 0 10-3.8 10-8.5S17.52 2 12 2z" fill="white"/></svg>
  </span>
  <span class="iko-toggle__icon" id="iko-icon-close" style="display:none">
    <svg width="20" height="20" fill="none" viewBox="0 0 20 20"><path d="M15 5L5 15M5 5l10 10" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
  </span>
</button>

<!-- Chat window -->
<div id="iko-window" class="iko-window" style="display:none">
  <div class="iko-header">
    <div class="iko-header__info">
      <div class="iko-header__avatar">IKO</div>
      <div>
        <div class="iko-header__name">IKO</div>
        <div class="iko-header__status">Assistant IKONIK</div>
      </div>
    </div>
  </div>
  <div class="iko-messages" id="iko-messages">
    <div class="iko-msg iko-msg--bot">
      <p>Bonjour ! Je suis IKO, l'assistant IKONIK. Comment puis-je vous aider ? Film, site web, SaaS, automatisation — posez-moi vos questions.</p>
    </div>
  </div>
  <div class="iko-input-wrap">
    <input type="text" id="iko-input" class="iko-input" placeholder="Votre question..." />
    <button id="iko-send" class="iko-send" aria-label="Envoyer">
      <svg width="18" height="18" fill="none" viewBox="0 0 18 18"><path d="M1 9l7-8v5h9L10 14V9H1z" fill="white"/></svg>
    </button>
  </div>
</div>

<style is:global>
.iko-toggle{align-items:center;background:#E9540D;border:none;border-radius:50%;bottom:2.4rem;box-shadow:0 4px 24px rgba(233,84,13,.4);cursor:pointer;display:flex;height:56px;justify-content:center;position:fixed;right:2.4rem;transition:transform .3s,box-shadow .3s;width:56px;z-index:9990}
.iko-toggle:hover{box-shadow:0 6px 32px rgba(233,84,13,.5);transform:scale(1.08)}
.iko-window{background:#0D1117;border-radius:20px 20px 4px 20px;bottom:9rem;box-shadow:0 12px 48px rgba(0,0,0,.5);display:flex;flex-direction:column;height:480px;max-height:70vh;overflow:hidden;position:fixed;right:2.4rem;width:380px;z-index:9991}
@media(max-width:480px){.iko-window{bottom:0;height:100vh;left:0;max-height:100vh;right:0;top:0;width:100%;border-radius:0}}
.iko-header{background:rgba(255,255,255,.06);border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;padding:1.6rem 2rem}
.iko-header__info{display:flex;align-items:center;gap:1.2rem}
.iko-header__avatar{align-items:center;background:#E9540D;border-radius:10px;color:#fff;display:flex;font-size:1.1rem;font-weight:700;height:36px;justify-content:center;letter-spacing:.06em;width:36px}
.iko-header__name{color:#fff;font-size:1.3rem;font-weight:600}
.iko-header__status{color:rgba(255,255,255,.4);font-size:1rem}
.iko-messages{display:flex;flex:1;flex-direction:column;gap:1rem;overflow-y:auto;padding:1.6rem}
.iko-msg p{font-size:1.3rem;line-height:1.9rem;margin:0 !important}
.iko-msg--bot p{background:rgba(255,255,255,.12);border-radius:14px 14px 14px 4px;color:#ffffff !important;padding:1rem 1.4rem}
.iko-msg--user p{background:#E9540D;border-radius:14px 14px 4px 14px;color:#ffffff !important;margin-left:auto;max-width:85%;padding:1rem 1.4rem}
.iko-msg--typing p{color:rgba(255,255,255,.6) !important;font-style:italic;background:none !important}
.iko-input-wrap{border-top:1px solid rgba(255,255,255,.08);display:flex;gap:.8rem;padding:1.2rem 1.6rem}
.iko-input{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:12px;color:#fff;flex:1;font-family:inherit;font-size:1.3rem;outline:none;padding:.9rem 1.2rem}
.iko-input:focus{border-color:rgba(233,84,13,.4)}
.iko-send{align-items:center;background:#E9540D;border:none;border-radius:10px;cursor:pointer;display:flex;height:40px;justify-content:center;width:40px;flex-shrink:0;transition:opacity .2s}
.iko-send:disabled{opacity:.4;cursor:default}
</style>

<script is:inline>
(function(){
  var SB='https://kgfolduvslsytbekbjvf.supabase.co';
  var chatHistory=[];
  var isOpen=false;

  document.getElementById('iko-toggle').addEventListener('click',function(){
    isOpen=!isOpen;
    document.getElementById('iko-window').style.display=isOpen?'flex':'none';
    document.getElementById('iko-icon-chat').style.display=isOpen?'none':'block';
    document.getElementById('iko-icon-close').style.display=isOpen?'block':'none';
    if(isOpen)document.getElementById('iko-input').focus();
  });

  async function sendMessage(){
    var input=document.getElementById('iko-input');
    var text=input.value.trim();
    if(!text)return;
    input.value='';
    
    // Add user message
    addMsg(text,'user');
    chatHistory.push({role:'user',content:text});
    
    // Show typing
    var typingEl=addMsg('IKO réfléchit...','typing');
    document.getElementById('iko-send').disabled=true;

    try{
      var res=await fetch(SB+'/functions/v1/ikonik-assistant',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({messages:chatHistory})
      });
      var data=await res.json();
      typingEl.remove();
      
      if(data.response){
        addMsg(data.response,'bot');
        chatHistory.push({role:'assistant',content:data.response});
      }else{
        addMsg("Hmm, je rencontre un souci technique. Contactez-nous directement à contact@ikonik-ac.com ou au +33 6 60 65 70 56.",'bot');
      }
    }catch(err){
      typingEl.remove();
      addMsg("Connexion impossible. Essayez de recharger la page ou contactez-nous à contact@ikonik-ac.com.",'bot');
    }
    document.getElementById('iko-send').disabled=false;

    // Track in IKONIK OS
    if(window.ikonikTrack)window.ikonikTrack('iko_chat',{description:'Chat with IKO assistant',message_count:chatHistory.length});
  }

  function addMsg(text,type){
    var div=document.createElement('div');
    div.className='iko-msg iko-msg--'+type;
    var p=document.createElement('p');
    p.textContent=text;
    div.appendChild(p);
    var container=document.getElementById('iko-messages');
    container.appendChild(div);
    container.scrollTop=container.scrollHeight;
    return div;
  }

  document.getElementById('iko-send').addEventListener('click',sendMessage);
  document.getElementById('iko-input').addEventListener('keydown',function(e){
    if(e.key==='Enter')sendMessage();
  });
})();
</script>
