---
// creatif.astro — Pôle Créatif IKONIK
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { supabase } from '../lib/supabase';

const CDN = 'https://d3aq9k5clbjrty.cloudfront.net';

// Fetch services créatifs depuis Supabase
let services: { title: string; description: string; tag?: string }[] = [];
try {
  const { data } = await supabase
    .from('services')
    .select('title, description')
    .eq('category', 'creatif')
    .order('id');
  if (data && data.length > 0) {
    services = data.map((s: any) => {
      let tag = 'Production';
      if (s.title.includes('social') || s.title.includes('Social') || s.title.includes('UGC')) tag = 'Contenu';
      if (s.title.includes('animé') || s.title.includes('Animé') || s.title.includes('Contenu animé')) tag = 'Production IA';
      if (s.title.includes('Films IA') || s.title.includes('FOOH')) tag = 'Production IA';
      if (s.title.includes('Documentaires') || s.title.includes('Films publicitaires')) tag = 'Production vidéo';
      return { ...s, tag };
    });
  }
} catch (_) {}

// Fallback statique avec textes validés par Johann
if (services.length === 0) {
  services = [
    { tag: 'Production vidéo', title: 'Films publicitaires', description: 'Spots TV, films de marque, publicités digitales. Du brief au rendu final — tournage réel, direction artistique, post-production cinématique.' },
    { tag: 'Production vidéo', title: 'Documentaires & Interviews', description: "Capturer l'authenticité. Documentaires corporate, portraits, témoignages — des récits qui donnent de la profondeur à votre marque." },
    { tag: 'Production IA', title: 'Films IA & FOOH', description: "Fake Out Of Home, spots générés par IA, environnements CGI photoréalistes. Le contenu viral de demain, produit aujourd'hui." },
    { tag: 'Production IA', title: 'Contenu animé', description: "Animation 2D/3D, motion design, univers visuels stylisés. Des formats qui captent l'attention là où la vidéo classique ne suffit plus." },
    { tag: 'Contenu', title: 'Contenu social', description: 'Formats courts, Reels, stories, carrousels. Des volumes calibrés pour chaque plateforme, sans sacrifier la qualité.' },
    { tag: 'Contenu', title: 'UGC IA', description: "Contenu authentique généré par l'intelligence artificielle. Des visuels crédibles, sans casting, sans tournage — l'efficacité au service de la créativité." },
  ];
}
---

<Base title="Production vidéo & contenu IA — IKONIK Créatif" description="Films publicitaires, documentaires, FOOH, contenu animé, contenu social, UGC IA. Production vidéo et production IA par IKONIK en Normandie.">

  <Header />

  <div class="layout layout--dark">
    <div class="layout__inner">

      <!-- HERO -->
      <section class="page-hero">
        <div class="page-hero__bg" style="background-image:url(/images/hero-creatif.webp)"></div>
        <div class="page-hero__inner">
          <div class="container">
            <h1 class="page-hero__title">
              <div class="hero-title">
                <span class="hero-line"><em>Créatif</em></span>
                <span class="hero-line">
                  <svg fill="none" viewBox="0 0 200 8" width="160" height="8" style="transform:rotate(180deg)">
                    <path d="M180 4H0" stroke="#FFFFFF"></path>
                    <path d="M200 0h-8v8h8V0Z" fill="#E9540D"></path>
                  </svg>
                  Films. Contenu. Image.
                </span>
              </div>
            </h1>
          </div>
        </div>
        <svg fill="none" viewBox="0 0 12 34" class="scroll-ind" aria-hidden="true">
          <path d="M12 0 6 8.195 0 0h12Z" fill="#E9540D"/>
          <path d="m12 25-6 8.195L0 25h12Z" fill="#FFF"/>
        </svg>
      </section>

      <!-- CONTENU -->
      <div class="layout__content">

        <!-- INTRO -->
        <div class="section t-light s-pad-lg">
          <div class="section__inner">
            <div class="container">
              <div class="grid grid--gap-lg rv">
                <div class="new-card">
                  <video autoplay muted playsinline loop preload="metadata" src="/videos/creatif.mp4" class="new-card__video"></video>
                </div>
                <div class="cb cb--l">
                  <div class="cb__h">
                    <span class="cb__tag">Pôle Créatif</span>
                    <h2>
                      <span class="h-line">
                        <span>IKONIK Créatif</span>
                        <svg fill="none" viewBox="0 0 200 11" width="140" height="11">
                          <path d="M177 5.5H0" stroke="#222931"></path>
                          <circle cx="194.5" cy="5.5" r="5.5" fill="#E9540D"></circle>
                        </svg>
                      </span>
                    </h2>
                  </div>
                  <div class="cb__wrap">
                    <p class="cb__t">Des films qui marquent, des images qui vendent. Production publicitaire, CGI photoréaliste, animation de marque — notre pipeline cinématique transforme chaque idée en contenu qui performe.</p>
                    <div class="cb__ctas">
                      <a class="button" href="/contact">
                        <span class="btn btn--pri">
                          <span class="bt bt--in">Lancer un projet</span>
                          <span class="bt bt--out" aria-hidden="true">Lancer un projet</span>
                        </span>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- SERVICES -->
        <div class="section t-light s-pb-lg">
          <div class="section__inner">
            <div class="container">
              <h2 class="rv" style="font-size:3.6rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-bottom:6rem">Nos services créatifs</h2>
              <div class="services-grid">
                {services.map((s) => (
                  <div class="service-card rv">
                    {s.tag && <span class="service-card__tag">{s.tag}</span>}
                    <h3 class="service-card__title">{s.title}</h3>
                    <p class="service-card__desc">{s.description}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- SÉLECTION DE PRODUCTIONS -->
        <div class="section t-light s-pad-lg">
          <div class="section__inner">
            <div class="container">
              <div class="rv" style="margin-bottom:6rem">
                <span class="cb__tag" style="display:block;margin-bottom:1.6rem">Nos réalisations</span>
                <h2 style="font-size:3.6rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase">Sélection <em style="font-family:var(--serif);font-style:italic;text-transform:none">de productions</em></h2>
              </div>
              <div class="productions-grid">
                <div class="production-card rv" onclick="openWistia('9rg8erhogc')" style="cursor:pointer">
                  <div class="production-card__img">
                    <img src="/images/sandro-chinatown.webp" alt="Film publicitaire IA Sandro — Chinatown" loading="lazy" />
                    <div class="play-btn" aria-label="Lire la vidéo">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="white"><polygon points="4,0 20,10 4,20"/></svg>
                    </div>
                  </div>
                  <div class="production-card__info">
                    <span class="production-card__cat">Film publicitaire IA</span>
                    <h3 class="production-card__title">Sandro Chinatown</h3>
                    <p class="production-card__desc">27 secondes · 100% IA</p>
                  </div>
                </div>
                <div class="production-card rv" onclick="openWistia('t427yb7j8z')" style="cursor:pointer">
                  <div class="production-card__img">
                    <img src="/images/cafe-san-marco.webp" alt="Film corporate Café San Marco" loading="lazy" />
                    <div class="play-btn" aria-label="Lire la vidéo">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="white"><polygon points="4,0 20,10 4,20"/></svg>
                    </div>
                  </div>
                  <div class="production-card__info">
                    <span class="production-card__cat">Film corporate</span>
                    <h3 class="production-card__title">Café San Marco</h3>
                    <p class="production-card__desc">Tournage réel · Brand content</p>
                  </div>
                </div>
                <div class="production-card rv" onclick="openWistia('2ytpjmvfi9')" style="cursor:pointer">
                  <div class="production-card__img">
                    <img src="/images/segafredo.webp" alt="Film de marque Segafredo" loading="lazy" />
                    <div class="play-btn" aria-label="Lire la vidéo">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="white"><polygon points="4,0 20,10 4,20"/></svg>
                    </div>
                  </div>
                  <div class="production-card__info">
                    <span class="production-card__cat">Film de marque</span>
                    <h3 class="production-card__title">Segafredo Zanetti</h3>
                    <p class="production-card__desc">60 secondes · 4K · IA + Réel</p>
                  </div>
                </div>
                <div class="production-card rv" onclick="openWistia('hehl6vkokj')" style="cursor:pointer">
                  <div class="production-card__img">
                    <img src="/images/bouillon-anime.webp" alt="Animation de marque Bouillon Italien" loading="lazy" />
                    <div class="play-btn" aria-label="Lire la vidéo">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="white"><polygon points="4,0 20,10 4,20"/></svg>
                    </div>
                  </div>
                  <div class="production-card__info">
                    <span class="production-card__cat">Animation IA</span>
                    <h3 class="production-card__title">Bouillon Italia</h3>
                    <p class="production-card__desc">Style anime · 100% IA</p>
                  </div>
                </div>
                <div class="production-card rv">
                  <div class="production-card__img">
                    <img src="/images/service-fooh.webp" alt="FOOH Fake Out Of Home" loading="lazy" />
                  </div>
                  <div class="production-card__info">
                    <span class="production-card__cat">FOOH</span>
                    <h3 class="production-card__title">Fake Out Of Home</h3>
                    <p class="production-card__desc">CGI photoréaliste · Viral</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- WISTIA LIGHTBOX MODAL -->
        <div id="wistia-modal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:#000">
          <button onclick="closeWistia()" style="position:absolute;top:1.2rem;right:1.2rem;background:rgba(0,0,0,.6);border:none;color:white;font-size:2.4rem;cursor:pointer;z-index:10001;width:44px;height:44px;display:flex;align-items:center;justify-content:center;border-radius:50%" aria-label="Fermer">&#10005;</button>
          <div id="wistia-container" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:100vw;height:56.25vw;max-height:100vh;max-height:100dvh;max-width:177.78vh"></div>
        </div>

        <!-- CTA DARK -->
        <div class="section t-dark s-pad-md">
          <div class="section__inner">
            <div class="container rv" style="text-align:center;color:#fff">
              <p style="font-size:1.2rem;font-weight:450;letter-spacing:.16em;text-transform:uppercase;margin-bottom:2rem">Votre projet créatif</p>
              <h2 style="font-size:3.6rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;max-width:800px;margin:0 auto 3rem">Donnons vie à votre vision</h2>
              <a class="button" href="/contact">
                <span class="btn btn--sec">
                  <span class="bt bt--in">Parler de votre projet</span>
                  <span class="bt bt--out" aria-hidden="true">Parler de votre projet</span>
                </span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <Footer />

</Base>

<script>
  // Reveal on scroll
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('rv--vis'); obs.unobserve(e.target); } });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.rv').forEach((el) => obs.observe(el));
</script>

<!-- Wistia Player -->
<script src="https://fast.wistia.com/assets/external/E-v1.js" async></script>
<script is:inline>
  function openWistia(hash) {
    var modal = document.getElementById('wistia-modal');
    var container = document.getElementById('wistia-container');
    container.innerHTML = '<div class="wistia_embed wistia_async_' + hash + ' videoFoam=true autoPlay=true" style="width:100%;height:100%">&nbsp;</div>';
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closeWistia() {
    var modal = document.getElementById('wistia-modal');
    var container = document.getElementById('wistia-container');
    container.innerHTML = '';
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeWistia();
  });
  document.getElementById('wistia-modal')?.addEventListener('click', function(e) {
    if (e.target === this) closeWistia();
  });
</script>
