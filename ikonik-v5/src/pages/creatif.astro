---
// creatif.astro — Pôle Créatif IKONIK
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { supabase } from '../lib/supabase';

const CDN = 'https://d3aq9k5clbjrty.cloudfront.net';

// Fetch services créatifs depuis Supabase (fallback statique si vide)
let services: { title: string; description: string; tag?: string }[] = [];
try {
  const { data } = await supabase
    .from('services')
    .select('title, description, tag')
    .eq('pole', 'creatif')
    .order('position');
  if (data && data.length > 0) services = data;
} catch (_) {}

// Fallback statique
if (services.length === 0) {
  services = [
    { tag: 'Production', title: 'Films IA', description: 'Films publicitaires génératifs — IA + mise en scène cinématique. Du brief au rendu final en temps record.' },
    { tag: 'Production', title: 'FOOH', description: 'Fake Out Of Home — publicité extérieure impossible rendue réelle. Viral, mémorable, partageable.' },
    { tag: 'Production', title: 'Animés & Art', description: 'Animation 2D/3D, motion design, art numérique. Des univers visuels cohérents et impactants.' },
    { tag: 'Contenu', title: 'Contenu Social', description: 'Formats courts, Reels, stories, UGC IA. Volumes de contenu élevés sans sacrifice de qualité.' },
    { tag: 'Contenu', title: 'UGC IA', description: "User Generated Content synthétique. Authenticité à l'échelle — sans casting, sans tournage." },
    { tag: 'Méthode', title: 'Composition Lock©', description: 'Notre workflow de production propriétaire. Délais réduits de 60%, qualité cinématique garantie.' },
  ];
}
---

<Base title="Créatif — IKONIK" description="Films IA, FOOH, animés, contenu social. Composition Lock© — notre workflow de production propriétaire.">

  <Header />

  <div class="layout layout--dark">
    <div class="layout__inner">

      <!-- HERO -->
      <section class="page-hero">
        <div class="page-hero__bg" style={`background-image:url(${CDN}/gallery/gallery-image-4.avif)`}></div>
        <div class="page-hero__inner">
          <div class="container">
            <h1 class="page-hero__title">
              <div class="hero-title">
                <span class="hero-line"><em>Créatif</em></span>
                <span class="hero-line">
                  <svg fill="none" viewBox="0 0 200 8" width="160" height="8" style="transform:rotate(180deg)">
                    <path d="M180 4H0" stroke="#FFFFFF"></path>
                    <path d="M200 0h-8v8h8V0Z" fill="#E9540D"></path>
                  </svg>
                  Films. Contenu. Image.
                </span>
              </div>
            </h1>
          </div>
        </div>
        <svg fill="none" viewBox="0 0 12 34" class="scroll-ind" aria-hidden="true">
          <path d="M12 0 6 8.195 0 0h12Z" fill="#E9540D"/>
          <path d="m12 25-6 8.195L0 25h12Z" fill="#FFF"/>
        </svg>
      </section>

      <!-- CONTENU -->
      <div class="layout__content">

        <!-- INTRO -->
        <div class="section t-light s-pad-lg">
          <div class="section__inner">
            <div class="container">
              <div class="grid grid--gap-lg rv">
                <div class="new-card">
                  <video autoplay muted playsinline loop src={`${CDN}/videos/video-4.mp4`} class="new-card__video"></video>
                </div>
                <div class="cb cb--l">
                  <div class="cb__h">
                    <span class="cb__tag">Pôle Créatif</span>
                    <h2>
                      <span class="h-line">
                        <span>IKONIK Créatif</span>
                        <svg fill="none" viewBox="0 0 200 11" width="140" height="11">
                          <path d="M177 5.5H0" stroke="#222931"></path>
                          <circle cx="194.5" cy="5.5" r="5.5" fill="#E9540D"></circle>
                        </svg>
                      </span>
                    </h2>
                  </div>
                  <div class="cb__wrap">
                    <p class="cb__t">Films IA, FOOH, animés, art & print, contenu social, UGC IA. Notre workflow propriétaire Composition Lock© réduit les délais de 60% sans compromis sur la qualité cinématique.</p>
                    <div class="cb__ctas">
                      <a class="button" href="/contact">
                        <span class="btn btn--pri">
                          <span class="bt bt--in">Lancer un projet</span>
                          <span class="bt bt--out" aria-hidden="true">Lancer un projet</span>
                        </span>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- SERVICES -->
        <div class="section t-light s-pb-lg">
          <div class="section__inner">
            <div class="container">
              <h2 class="rv" style="font-size:3.6rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-bottom:6rem">Nos services créatifs</h2>
              <div class="services-grid">
                {services.map((s) => (
                  <div class="service-card rv">
                    {s.tag && <span class="service-card__tag">{s.tag}</span>}
                    <h3 class="service-card__title">{s.title}</h3>
                    <p class="service-card__desc">{s.description}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- CTA DARK -->
        <div class="section t-dark s-pad-md">
          <div class="section__inner">
            <div class="container rv" style="text-align:center;color:#fff">
              <p style="font-size:1.2rem;font-weight:450;letter-spacing:.16em;text-transform:uppercase;margin-bottom:2rem">Composition Lock©</p>
              <h2 style="font-size:3.6rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;max-width:800px;margin:0 auto 3rem">Le pipeline cinématique qui fait la différence</h2>
              <a class="button" href="/contact">
                <span class="btn btn--sec">
                  <span class="bt bt--in">Parler de votre projet</span>
                  <span class="bt bt--out" aria-hidden="true">Parler de votre projet</span>
                </span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <Footer />

</Base>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('rv--vis'); obs.unobserve(e.target); } });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.rv').forEach((el) => obs.observe(el));
</script>
