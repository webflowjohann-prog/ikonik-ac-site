---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Page introuvable — IKONIK" description="La page que vous recherchez n'existe pas.">
  <Header />
  <main class="section t-dark s-pad-lg" style="min-height:70vh;display:flex;align-items:center;justify-content:center;text-align:center">
    <div>
      <p style="color:var(--accent);font-size:1.2rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;margin-bottom:1.6rem">Erreur 404</p>
      <h1 style="font-family:var(--serif);font-size:4.8rem;font-weight:300;color:var(--white);margin-bottom:2.4rem">Page introuvable</h1>
      <p style="color:rgba(255,255,255,0.6);font-size:1.6rem;margin-bottom:4rem;max-width:48rem">La page que vous recherchez n'existe pas ou a été déplacée.</p>
      <a href="/" style="display:inline-block;background:var(--accent);color:#fff;padding:1.4rem 4rem;border-radius:50px;font-size:1.3rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;text-decoration:none">Retour à l'accueil</a>
    </div>
  </main>
  <Footer />
</Base>
