---
// index.astro — Home Page IKONIK V5
// Structure validée par Johann : Hero + 2 Portes + Quote + TextCards + FeatureCard + Gallery + ReviewSection + SignUp + Articles + Footer
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import HeroVideo from '../components/HeroVideo.astro';
import ProductGate from '../components/ProductGate.astro';
import Quote from '../components/Quote.astro';
import TextCard from '../components/TextCard.astro';
import FeatureCard from '../components/FeatureCard.astro';
import GalleryRow from '../components/GalleryRow.astro';
import ReviewSection from '../components/ReviewSection.astro';
import SignUp from '../components/SignUp.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

// Assets Warwick CDN (remplacés par assets IKONIK ultérieurement)
const CDN = 'https://d3aq9k5clbjrty.cloudfront.net';

// Fetch 3 derniers articles du blog
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Base title="IKONIK — Nous construisons les outils, les contenus et les systèmes qui font vendre.">

  <Header />

  <div class="layout layout--dark">
    <div class="layout__inner">

      <!-- 1. HERO — vidéo plein écran -->
      <HeroVideo
        videoSrc="/videos/hero-background.mp4"
        subtitle="Créer. Construire. Vendre."
      />

      <!-- CONTENU PRINCIPAL -->
      <div class="layout__content">

        <!-- 2. LES DEUX PORTES CRÉATIF / TECH -->
        <div class="section t-light s-pad-lg">
          <div class="section__inner">
            <div class="container">
              <div style="display:flex;flex-direction:column;gap:8rem">

                <!-- Porte 1 : CRÉATIF (vidéo gauche, texte droite) -->
                <ProductGate
                  tag="Pôle Créatif"
                  title="IKONIK Créatif"
                  description="Des films qui marquent, des images qui vendent. Production publicitaire, CGI photoréaliste, animation de marque — notre pipeline cinématique transforme chaque idée en contenu qui performe."
                  ctaLabel="Découvrir le créatif"
                  ctaHref="/creatif"
                  videoSrc="/videos/creatif.mp4"
                  posterSrc="/videos/creatif-poster.jpg"
                  accentType="dot"
                  reversed={false}
                />

                <!-- Porte 2 : TECH (texte gauche, vidéo droite — inversé) -->
                <ProductGate
                  tag="Pôle Tech"
                  title="IKONIK Tech"
                  description="Des plateformes qui tournent, des systèmes qui convertissent. On construit vos outils métiers sur mesure — du CRM au SaaS — l'IA intégrée à chaque étape de votre chaîne de valeur."
                  ctaLabel="Découvrir la tech"
                  ctaHref="/tech"
                  videoSrc="/videos/tech.mp4"
                  posterSrc="/videos/tech-poster.jpg"
                  accentType="chevron"
                  reversed={true}
                />

              </div>
            </div>
          </div>
        </div>

        <!-- 3. QUOTE -->
        <div class="section t-light s-pad-md">
          <div class="section__inner">
            <div class="container">
              <Quote
                text="Nous ne faisons pas de la communication — nous construisons des systèmes qui génèrent de la valeur."
                author="Johann — Fondateur IKONIK"
              />
            </div>
          </div>
        </div>

        <!-- 4. TEXT CARDS — 3 colonnes -->
        <div class="section t-light s-pb-lg">
          <div class="section__inner">
            <div class="container">
              <div class="text-cards">
                <TextCard
                  label="Un seul studio, deux expertises"
                  description="Créatif et tech sous le même toit. Pas de sous-traitance, pas de perte d'information — chaque projet est piloté de bout en bout."
                  imageSrc="/images/card-studio.webp"
                />
                <TextCard
                  label="Pensé pour convertir"
                  description="Chaque image, chaque ligne de code, chaque automatisation est conçue avec un seul objectif : transformer l'attention en action."
                  imageSrc="/images/card-convert.webp"
                />
                <TextCard
                  label="Construit pour durer"
                  description="Pas de dette technique, pas de tendances jetables. On crée des actifs qui prennent de la valeur dans le temps."
                  imageSrc="/images/card-durable.webp"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- 5. SECTION SOMBRE — Feature card plein écran -->
        <div class="section t-dark s-pt-lg s-pb-sm">
          <div class="section__inner">
            <div class="container">
              <div style="display:flex;flex-direction:column;gap:8rem">

                <FeatureCard
                  tag="Notre engagement"
                  titleParts={['Pas de', 'compromis']}
                  description="On ne sépare jamais la stratégie de l'exécution. Chaque projet passe par notre pipeline intégré — créatif, tech, déploiement — sans perte, sans délai, sans excuse."
                  ctaLabel="Notre philosophie"
                  ctaHref="/studio"
                  bgImage="/images/feature-compromis.webp"
                  theme="dark"
                  accentType="dot"
                />

                <!-- 6. GALERIE ASYMÉTRIQUE -->
                <GalleryRow
                  items={[
                    { type: 'image', src: '/images/gallery-collab.webp', alt: 'Équipe IKONIK en studio' },
                    { type: 'image', src: '/images/gallery-analytics.webp', alt: 'Dashboard analytics IKONIK' },
                    { type: 'image', src: '/images/gallery-camera.webp', alt: 'Production cinématique IKONIK' },
                  ]}
                />

                <!-- 7. FEATURE CARD 2 -->
                <FeatureCard
                  tag="Ce qu'on délivre"
                  titleParts={['Chaque projet', 'performe']}
                  description="On ne mesure pas notre travail en livrables — on le mesure en impact. Taux de conversion, coût d'acquisition, engagement, revenus. On itère jusqu'à trouver la bonne formule."
                  ctaLabel="Voir les projets"
                  ctaHref="/studio"
                  bgImage="/images/feature-performe.webp"
                  theme="dark"
                  accentType="chevron"
                />

                <!-- 8. REVIEW SECTION -->
                <ReviewSection
                  media={[
                    { type: 'image', src: '/images/review-01.webp' },
                    { type: 'image', src: '/images/review-02.webp' },
                    { type: 'image', src: '/images/review-03.webp' },
                    { type: 'image', src: '/images/review-04.webp' },
                  ]}
                  quote="On cherchait un partenaire capable de penser le contenu ET la tech. En 3 mois, ils ont refait notre tunnel d'acquisition et produit les assets vidéo qui l'alimentent. Les résultats ont suivi."
                  author="Directeur marketing"
                  source="E-commerce"
                  ctaLabel="Voir les témoignages"
                  ctaHref="/studio"
                  theme="dark"
                />

              </div>
            </div>
          </div>
        </div>

        <!-- 9. SIGN UP -->
        <div class="section s-pad-md">
          <div class="section__inner">
            <div class="container">
              <SignUp />
            </div>
          </div>
        </div>

        <!-- 10. ARTICLES -->
        <div class="section t-light s-pb-lg">
          <div class="section__inner">
            <div class="container">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6rem">
                <h2 style="font-size:3.6rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase">Journal</h2>
                <a class="button" href="/blog">
                  <span class="btn btn--ter">
                    <span class="bt bt--in">Tous les articles</span>
                    <span class="bt bt--out" aria-hidden="true">Tous les articles</span>
                  </span>
                </a>
              </div>
              <div class="articles-grid">
                {latestPosts.map((post) => (
                  <ArticleCard
                    tag={post.data.category}
                    title={post.data.title}
                    excerpt={post.data.excerpt}
                    href={`/blog/${post.data.slug}`}
                    color={post.data.color}
                    date={new Date(post.data.date).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}
                  />
                ))}
              </div>
            </div>
          </div>
        </div>

      </div><!-- .layout__content -->
    </div>
  </div>

  <Footer />

</Base>

<script>
  // Scroll reveal — IntersectionObserver
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('rv--vis');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.rv').forEach((el) => observer.observe(el));
</script>
