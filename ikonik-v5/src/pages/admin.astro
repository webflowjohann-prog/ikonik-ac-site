async function loadBrain(){
  var data=await q('brain?select=type,titre,tags,created_at&order=created_at.desc&limit=20');
  document.getElementById('brain-tbody').innerHTML=data.length?data.map(function(b){return'<tr><td><span class="badge badge--gold">'+b.type+'</span></td><td>'+b.titre+'</td><td style="color:var(--muted)">'+(b.tags||'')+'</td><td style="color:var(--muted)">'+dateFr(b.created_at)+'</td></tr>'}).join(''):'<tr><td colspan="4" class="empty">Aucune capture</td></tr>';
}
function showBrainMode(mode){if(mode==='home'){document.getElementById('brain-home').style.display='block';document.getElementById('brain-form').style.display='none';return}brainMode=mode;document.getElementById('brain-home').style.display='none';document.getElementById('brain-form').style.display='block';document.getElementById('brain-form-title').textContent=mode==='link'?'Nouveau lien':mode==='idea'?'Nouvelle idee':'Photo';document.getElementById('brain-link-fields').style.display=mode==='link'?'block':'none';brainTags=[]}
document.querySelectorAll('#br-tags .tag-btn').forEach(function(b){b.addEventListener('click',function(){this.classList.toggle('active');var t=this.dataset.t;var i=brainTags.indexOf(t);if(i>-1)brainTags.splice(i,1);else brainTags.push(t)})});
document.getElementById('br-save').addEventListener('click',async function(){this.disabled=true;this.textContent='Enregistrement...';var title=document.getElementById('br-title').value;var note=document.getElementById('br-note').value;try{await fetch(SB+'/rest/v1/brain',{method:'POST',headers:HP,body:JSON.stringify({type:brainMode,titre:title||'Sans titre',contenu:note,url:brainMode==='link'?document.getElementById('br-url').value:null,tags:brainTags.length?'{'+brainTags.join(',')+'}':'{}',categorie:brainTags[0]||'autre'})});alert('Enregistre');showBrainMode('home');loadBrain()}catch(e){alert('Erreur')}this.disabled=false;this.textContent='Sauvegarder'});

// ═══ ACTIVITE ═══
async function loadActivity(){
  var data=await q('activity_log?select=action,description,created_at&order=created_at.desc&limit=50');
  document.getElementById('activity-tbody').innerHTML=data.length?data.map(function(a){return'<tr><td><span class="badge badge--gold">'+a.action+'</span></td><td style="color:var(--muted)">'+((a.description||'').slice(0,80))+'</td><td style="color:var(--muted);white-space:nowrap">'+dateFr(a.created_at)+'</td></tr>'}).join(''):'<tr><td colspan="3" class="empty">Aucune activite</td></tr>';
}
</script>
</body>
</html>
