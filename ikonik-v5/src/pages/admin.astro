---
// admin.astro — IKONIK OS · Unified Command Center
---
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="noindex, nofollow" />
<meta name="color-scheme" content="dark" />
<title>IKONIK OS — Command Center</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0D1117;--card:#161B22;--border:#21262D;--text:#E6EDF3;--muted:#8B949E;--gold:#b8963e;--gold-light:#d4b062;--green:#3FB950;--blue:#4BB2F2;--red:#F85149;--sidebar-w:220px}
body{background:var(--bg);color:var(--text);font-family:'Outfit',system-ui,sans-serif;font-size:14px;min-height:100vh}
a{color:var(--blue);text-decoration:none}

/* AUTH */
.auth{align-items:center;display:flex;flex-direction:column;gap:2rem;height:100vh;justify-content:center}
.auth__logo{height:3rem;opacity:.8}
.auth__tag{color:var(--gold);font-size:.85rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase}
.auth__input{background:var(--card);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:inherit;font-size:1rem;padding:.8rem 1.2rem;text-align:center;width:280px}
.auth__input:focus{border-color:var(--gold);outline:none}
.auth__btn{background:var(--gold);border:none;border-radius:8px;color:#fff;cursor:pointer;font-family:inherit;font-weight:600;padding:.8rem 2rem}

/* LAYOUT */
.app{display:none;min-height:100vh}
.sidebar{background:var(--card);border-right:1px solid var(--border);display:flex;flex-direction:column;height:100vh;left:0;position:fixed;top:0;width:var(--sidebar-w);z-index:100}
.sb-brand{border-bottom:1px solid var(--border);padding:24px 20px}
.sb-name{font-size:20px;font-weight:700;letter-spacing:1px}
.sb-tagline{color:var(--gold);font-size:11px;font-style:italic;margin-top:2px}
.sb-nav{display:flex;flex-direction:column;gap:2px;padding:16px 12px;flex:1;overflow-y:auto}
.sb-item{align-items:center;border-radius:8px;color:var(--muted);cursor:pointer;display:flex;font-size:13px;gap:10px;padding:10px 12px;transition:all .2s;border:none;background:none;font-family:inherit;width:100%;text-align:left}
.sb-item:hover{background:rgba(255,255,255,.04);color:var(--text)}
.sb-item.active{background:rgba(184,150,62,.12);color:var(--gold-light);font-weight:600}
.sb-item svg{flex-shrink:0;width:16px;height:16px}
.sb-footer{border-top:1px solid var(--border);padding:12px}
.sb-footer a{color:var(--muted);display:flex;align-items:center;gap:8px;font-size:12px;padding:8px 12px;border-radius:6px}
.sb-footer a:hover{color:var(--text);background:rgba(255,255,255,.04)}
.main{margin-left:var(--sidebar-w);min-height:100vh;padding:28px 32px}
.main__header{display:flex;justify-content:space-between;align-items:center;margin-bottom:28px}
.main__title{font-size:22px;font-weight:600}
.main__sub{color:var(--muted);font-size:13px;margin-top:4px}
.section{display:none}
.section.active{display:block}

/* CARDS & KPIS */
.kpis{display:grid;gap:12px;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));margin-bottom:28px}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px 18px}
.kpi__label{color:var(--muted);font-size:11px;letter-spacing:1px;text-transform:uppercase}
.kpi__val{font-size:28px;font-weight:700;margin-top:6px}
.card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:18px 20px}
.card__title{font-size:13px;font-weight:600;margin-bottom:14px}
.grid-2{display:grid;gap:16px;grid-template-columns:1.4fr 1fr}
@media(max-width:900px){.grid-2{grid-template-columns:1fr}}

/* TABLE */
.tbl{width:100%;border-collapse:collapse}
.tbl th{color:var(--muted);font-size:11px;font-weight:500;letter-spacing:1px;padding:8px 12px;text-align:left;text-transform:uppercase;border-bottom:1px solid var(--border)}
.tbl td{border-bottom:1px solid rgba(255,255,255,.04);font-size:13px;padding:12px}
.tbl tr:hover{background:rgba(255,255,255,.02)}
.tbl tr{cursor:pointer}
.badge{border-radius:4px;font-size:10px;font-weight:600;padding:3px 8px;display:inline-block}
.badge--green{background:rgba(63,185,80,.15);color:var(--green)}
.badge--blue{background:rgba(75,178,242,.15);color:var(--blue)}
.badge--gold{background:rgba(184,150,62,.15);color:var(--gold-light)}
.badge--red{background:rgba(248,81,73,.15);color:var(--red)}
.badge--muted{background:rgba(139,148,158,.15);color:var(--muted)}

/* AVATAR */
.avatar{align-items:center;background:rgba(184,150,62,.15);border-radius:50%;color:var(--gold);display:flex;font-size:11px;font-weight:600;height:32px;justify-content:center;width:32px;flex-shrink:0}

/* FORMS */
.f-row{display:grid;gap:16px;grid-template-columns:1fr 1fr;margin-bottom:16px}
@media(max-width:600px){.f-row{grid-template-columns:1fr}}
.f-group{display:flex;flex-direction:column;gap:4px;margin-bottom:16px}
.f-label{color:var(--muted);font-size:11px;font-weight:500;letter-spacing:.08em;text-transform:uppercase}
.f-inp{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:inherit;font-size:14px;padding:10px 14px}
.f-inp:focus{border-color:var(--gold);outline:none}
select.f-inp{appearance:auto}
textarea.f-inp{resize:vertical;min-height:80px}
.btn{border:none;border-radius:8px;cursor:pointer;font-family:inherit;font-size:13px;font-weight:600;padding:10px 20px}
.btn--gold{background:var(--gold);color:#fff}
.btn--gold:hover{background:#a6862f}
.btn--sec{background:rgba(255,255,255,.06);border:1px solid var(--border);color:var(--text)}
.btn--sec:hover{background:rgba(255,255,255,.1)}
.btn--sm{font-size:12px;padding:6px 14px}
.btn:disabled{opacity:.4;cursor:wait}
.empty{color:var(--muted);padding:3rem;text-align:center}

/* TABS inner */
.tabs-inner{display:flex;gap:8px;margin-bottom:20px}
.tab-inner{background:var(--card);border:1px solid var(--border);border-radius:8px;color:var(--muted);cursor:pointer;font-family:inherit;font-size:13px;padding:8px 16px}
.tab-inner.active{background:rgba(184,150,62,.12);border-color:var(--gold);color:var(--gold-light)}

/* RADIO CARDS & PILLS (booking/contact/invoice) */
.rc-group{display:grid;gap:10px;grid-template-columns:repeat(3,1fr);margin-bottom:16px}
@media(max-width:600px){.rc-group{grid-template-columns:1fr}}
.rc{cursor:pointer}
.rc input{display:none}
.rc__inner{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;display:flex;flex-direction:column;align-items:center;gap:4px;padding:14px;text-align:center;transition:all .2s}
.rc input:checked+.rc__inner{background:rgba(184,150,62,.1);border-color:var(--gold)}
.rc__title{font-size:14px;font-weight:600}
.rc__desc{color:var(--muted);font-size:11px}
.pill-group{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px}
.pill{cursor:pointer}
.pill input{display:none}
.pill span{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:20px;color:var(--muted);display:inline-block;font-size:12px;padding:6px 14px;transition:all .2s}
.pill input:checked+span{background:rgba(184,150,62,.1);border-color:var(--gold);color:var(--gold-light);font-weight:500}

/* INVOICE LINES */
.inv-lines{margin:16px 0}
.inv-line{display:grid;gap:8px;grid-template-columns:3fr 1fr 1fr 1fr 32px;margin-bottom:6px;align-items:center}
.inv-line input{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:inherit;font-size:13px;padding:8px 10px}
.inv-line input:focus{border-color:var(--gold);outline:none}
.inv-line-del{background:none;border:none;color:var(--red);cursor:pointer;font-size:16px}
.inv-line-total{color:var(--muted);font-size:13px;text-align:right;padding:8px}
.add-line-btn{background:none;border:1px dashed var(--border);border-radius:8px;color:var(--muted);cursor:pointer;font-family:inherit;font-size:13px;padding:10px;width:100%}
.add-line-btn:hover{border-color:var(--gold);color:var(--gold)}
.totals{border-top:1px solid var(--border);display:flex;flex-direction:column;align-items:flex-end;gap:6px;margin-top:16px;padding-top:16px}
.totals__row{display:flex;gap:24px;font-size:14px}
.totals__row span:first-child{color:var(--muted);min-width:100px;text-align:right}
.totals__row span:last-child{font-weight:500;min-width:100px;text-align:right}
.totals__row--big span:last-child{font-size:18px;font-weight:700;color:var(--gold-light)}

/* BOOKING slots */
.bk-days{display:flex;gap:8px;margin-bottom:16px;overflow-x:auto;padding-bottom:8px;scrollbar-width:none}
.bk-days::-webkit-scrollbar{display:none}
.bk-day{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;color:var(--text);cursor:pointer;flex-shrink:0;font-family:inherit;font-size:12px;padding:10px 14px;text-align:center;transition:all .2s;min-width:64px}
.bk-day:hover{border-color:var(--gold)}
.bk-day.active{background:rgba(184,150,62,.1);border-color:var(--gold);color:var(--gold-light);font-weight:600}
.bk-day-name{display:block;font-weight:500;margin-bottom:4px;text-transform:uppercase;letter-spacing:.08em;font-size:10px}
.bk-day-date{display:block;font-size:14px;font-weight:600}
.bk-slots{display:grid;gap:8px;grid-template-columns:repeat(4,1fr)}
@media(max-width:600px){.bk-slots{grid-template-columns:repeat(2,1fr)}}
.bk-slot{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:8px;color:var(--text);cursor:pointer;font-family:inherit;font-size:13px;font-weight:500;padding:10px;text-align:center;transition:all .2s}
.bk-slot:hover{border-color:var(--gold);color:var(--gold-light)}
.bk-slot.active{background:var(--gold);border-color:var(--gold);color:#fff}

/* BRAIN modes */
.brain-modes{display:grid;gap:12px;grid-template-columns:repeat(3,1fr);margin-bottom:24px}
@media(max-width:600px){.brain-modes{grid-template-columns:1fr}}
.brain-mode{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:12px;color:var(--text);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:8px;padding:20px 16px;transition:all .2s;font-family:inherit;text-align:center}
.brain-mode:hover{border-color:var(--gold);background:rgba(184,150,62,.06)}
.brain-mode-icon{font-size:24px}
.brain-mode-name{font-size:14px;font-weight:600}
.brain-mode-desc{color:var(--muted);font-size:11px}
.tag-row{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px}
.tag-btn{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:20px;color:var(--muted);cursor:pointer;font-family:inherit;font-size:12px;padding:6px 14px;transition:all .2s}
.tag-btn.active{background:rgba(184,150,62,.12);border-color:var(--gold);color:var(--gold-light)}

/* MOBILE */
@media(max-width:768px){
  .sidebar{width:60px;overflow:hidden}
  .sb-brand{padding:16px 12px}
  .sb-name,.sb-tagline,.sb-item span:not(svg),.sb-footer span{display:none}
  .sb-item{justify-content:center;padding:12px}
  .main{margin-left:60px;padding:16px}
  .kpis{grid-template-columns:repeat(2,1fr)}
}
</style>
</head>
<body>

<!-- AUTH -->
<div class="auth" id="auth-screen">
  <img src="/images/LOGO_IKONIK_blanc.webp" alt="IKONIK" class="auth__logo" />
  <p class="auth__tag">Command Center</p>
  <input type="password" id="auth-pass" class="auth__input" placeholder="Mot de passe" autofocus />
  <button class="auth__btn" id="auth-btn">Acceder</button>
</div>

<!-- APP -->
<div class="app" id="app">

  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="sb-brand"><div class="sb-name">IKONIK</div><div class="sb-tagline">Command Center</div></div>
    <div class="sb-nav">
      <button class="sb-item active" data-section="dashboard"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg><span>Dashboard</span></button>
      <button class="sb-item" data-section="contacts"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg><span>Contacts</span></button>
      <button class="sb-item" data-section="booking"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg><span>Booking</span></button>
      <button class="sb-item" data-section="facturation"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg><span>Facturation</span></button>
      <button class="sb-item" data-section="brain"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg><span>Brain</span></button>
      <button class="sb-item" data-section="activite"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg><span>Activite</span></button>
    </div>
    <div class="sb-footer"><a href="/"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg><span>Retour au site</span></a></div>
  </nav>

  <!-- MAIN CONTENT -->
  <div class="main">
    <div class="main__header">
      <div><div class="main__title" id="page-title">Dashboard</div><div class="main__sub" id="page-sub">Vue d'ensemble IKONIK OS</div></div>
      <div style="font-size:12px;color:var(--muted);background:var(--card);border:1px solid var(--border);padding:6px 14px;border-radius:6px">Johann Langenberg</div>
    </div>

    <!-- ═══ SECTION: DASHBOARD ═══ -->
    <div class="section active" id="sec-dashboard">
      <div class="kpis" id="kpis"></div>
      <div class="grid-2">
        <div class="card"><div class="card__title">Derniers contacts</div><div id="dash-contacts"><div class="empty">Chargement...</div></div></div>
        <div class="card"><div class="card__title">Prochains RDV</div><div id="dash-bookings"><div class="empty">Chargement...</div></div></div>
      </div>
      <div class="card" style="margin-top:16px"><div class="card__title">Activite recente</div><div id="dash-activity"><div class="empty">Chargement...</div></div></div>
    </div>

    <!-- ═══ SECTION: CONTACTS ═══ -->
    <div class="section" id="sec-contacts">
      <div class="tabs-inner" id="contacts-filters">
        <button class="tab-inner active" data-filter="all">Tous</button>
        <button class="tab-inner" data-filter="nouveau">Nouveaux</button>
        <button class="tab-inner" data-filter="alerte_envoyee">Alertes</button>
        <button class="tab-inner" data-filter="relance_envoyee">Relances</button>
      </div>
      <div class="card"><table class="tbl"><thead><tr><th>Nom</th><th>Email</th><th>Type</th><th>Budget</th><th>Score</th><th>Statut</th><th>Date</th></tr></thead><tbody id="contacts-tbody"></tbody></table></div>
    </div>

    <!-- ═══ SECTION: BOOKING ═══ -->
    <div class="section" id="sec-booking">
      <div class="card">
        <div class="card__title">Creneaux disponibles</div>
        <div class="bk-days" id="adm-bk-days"></div>
        <div class="bk-slots" id="adm-bk-slots"><div class="empty">Chargement...</div></div>
      </div>
      <div id="adm-bk-form" style="display:none" class="card" style="margin-top:16px">
        <div class="card__title">Confirmer le creneau : <span id="adm-bk-selected" style="color:var(--gold-light)"></span></div>
        <div class="f-row"><div class="f-group"><label class="f-label">Nom</label><input class="f-inp" id="adm-bk-nom" required /></div><div class="f-group"><label class="f-label">Email</label><input class="f-inp" id="adm-bk-email" required type="email" /></div></div>
        <div class="f-row"><div class="f-group"><label class="f-label">Telephone</label><input class="f-inp" id="adm-bk-tel" /></div><div class="f-group"><label class="f-label">Type</label><select class="f-inp" id="adm-bk-type"><option value="decouverte">Decouverte</option><option value="projet">Projet</option><option value="suivi">Suivi</option></select></div></div>
        <button class="btn btn--gold" id="adm-bk-submit" style="width:100%;margin-top:8px">Confirmer la reservation</button>
      </div>
      <div class="card" style="margin-top:16px"><div class="card__title">Reservations a venir</div><table class="tbl"><thead><tr><th>Date</th><th>Heure</th><th>Nom</th><th>Email</th><th>Type</th></tr></thead><tbody id="bookings-tbody"></tbody></table></div>
    </div>

    <!-- ═══ SECTION: FACTURATION ═══ -->
    <div class="section" id="sec-facturation">
      <div class="tabs-inner">
        <button class="tab-inner active" onclick="showInvTab('list')">Factures</button>
        <button class="tab-inner" onclick="showInvTab('new')">+ Nouvelle facture</button>
      </div>
      <div id="inv-tab-list" class="card"><table class="tbl"><thead><tr><th>Numero</th><th>Client</th><th>Total TTC</th><th>Statut</th><th>Date</th></tr></thead><tbody id="inv-tbody"></tbody></table></div>
      <div id="inv-tab-new" class="card" style="display:none">
        <div class="card__title">Nouvelle facture</div>
        <div class="f-row"><div class="f-group"><label class="f-label">Type</label><select class="f-inp" id="inv-type"><option value="facture">Facture</option><option value="devis">Devis</option><option value="avoir">Avoir</option></select></div><div class="f-group"><label class="f-label">Date</label><input type="date" class="f-inp" id="inv-date" /></div></div>
        <div class="f-row"><div class="f-group"><label class="f-label">Client</label><input class="f-inp" id="inv-client" placeholder="Nom du client" /></div><div class="f-group"><label class="f-label">Email</label><input class="f-inp" id="inv-email" placeholder="email@client.com" /></div></div>
        <div class="f-row"><div class="f-group"><label class="f-label">Adresse</label><input class="f-inp" id="inv-adresse" placeholder="Adresse complete" /></div><div class="f-group"><label class="f-label">SIRET client</label><input class="f-inp" id="inv-siret" placeholder="Optionnel" /></div></div>
        <div class="f-row"><div class="f-group"><label class="f-label">Echeance</label><select class="f-inp" id="inv-echeance"><option value="30">30 jours</option><option value="15">15 jours</option><option value="45">45 jours</option><option value="0">A reception</option></select></div><div class="f-group"><label class="f-label">TVA (%)</label><input type="number" class="f-inp" id="inv-tva" value="20" min="0" max="100" /></div></div>
        <div class="inv-lines"><div style="display:grid;gap:8px;grid-template-columns:3fr 1fr 1fr 1fr 32px;margin-bottom:8px;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em"><span>Description</span><span>Qte</span><span>Prix HT</span><span>Total</span><span></span></div><div id="inv-lines"></div><button class="add-line-btn" onclick="addInvLine()">+ Ajouter une ligne</button></div>
        <div class="totals"><div class="totals__row"><span>Sous-total HT</span><span id="inv-st">0,00 EUR</span></div><div class="totals__row"><span>TVA (<span id="inv-tp">20</span>%)</span><span id="inv-tv">0,00 EUR</span></div><div class="totals__row totals__row--big"><span>Total TTC</span><span id="inv-tt">0,00 EUR</span></div></div>
        <div style="display:flex;gap:10px;margin-top:16px"><button class="btn btn--gold" onclick="saveInvoice()">Enregistrer</button><button class="btn btn--sec" onclick="previewInvoice()">Apercu / PDF</button></div>
      </div>
      <div id="inv-preview" style="display:none"></div>
    </div>

    <!-- ═══ SECTION: BRAIN ═══ -->
    <div class="section" id="sec-brain">
      <div id="brain-home">
        <div class="brain-modes">
          <button class="brain-mode" onclick="showBrainMode('link')"><span class="brain-mode-icon">&#128279;</span><span class="brain-mode-name">Lien web</span><span class="brain-mode-desc">R&D, veille, inspiration</span></button>
          <button class="brain-mode" onclick="showBrainMode('idea')"><span class="brain-mode-icon">&#128161;</span><span class="brain-mode-name">Idee</span><span class="brain-mode-desc">Note rapide, boite a idees</span></button>
          <button class="brain-mode" onclick="showBrainMode('photo')"><span class="brain-mode-icon">&#128247;</span><span class="brain-mode-name">Photo</span><span class="brain-mode-desc">Document, reference visuelle</span></button>
        </div>
        <div class="card"><div class="card__title">Dernieres captures</div><table class="tbl"><thead><tr><th>Type</th><th>Titre</th><th>Tags</th><th>Date</th></tr></thead><tbody id="brain-tbody"></tbody></table></div>
      </div>
