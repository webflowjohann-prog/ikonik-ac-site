---
// blog/index.astro — Journal IKONIK (Astro Content Collections)
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Footer from '../../components/Footer.astro';

const posts = await getCollection('blog');

// Tri par date décroissante
const sorted = posts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base
  title="Journal — Articles IA, vidéo & développement | IKONIK"
  description="Articles, analyses et retours d'expérience sur la production vidéo, l'intelligence artificielle, le développement web et l'automatisation par IKONIK."
>
  <Header />

  <div class="layout layout--dark">
    <div class="layout__inner">

      <!-- HERO -->
      <section class="page-hero">
        <div class="page-hero__bg" style="background-image:url(/images/gallery-collab.webp)"></div>
        <div class="page-hero__inner">
          <div class="container">
            <h1 class="page-hero__title">
              <div class="hero-title">
                <span class="hero-line">Journal</span>
                <span class="hero-line">
                  <em>IKONIK</em>
                  <svg fill="none" viewBox="0 0 200 11" width="160" height="11">
                    <path d="M177 5.5H0" stroke="#FFFFFF"></path>
                    <circle cx="194.5" cy="5.5" r="5.5" fill="#E9540D"></circle>
                  </svg>
                </span>
              </div>
            </h1>
          </div>
        </div>
        <svg fill="none" viewBox="0 0 12 34" class="scroll-ind" aria-hidden="true">
          <path d="M12 0 6 8.195 0 0h12Z" fill="#E9540D"/>
          <path d="m12 25-6 8.195L0 25h12Z" fill="#FFF"/>
        </svg>
      </section>

      <!-- ARTICLES -->
      <div class="layout__content">
        <div class="section t-light s-pad-lg">
          <div class="section__inner">
            <div class="container">

              <p class="blog-count rv">{sorted.length} articles</p>

              <div class="articles-grid">
                {sorted.map((post) => (
                  <ArticleCard
                    tag={post.data.category}
                    title={post.data.title}
                    excerpt={post.data.excerpt}
                    href={`/blog/${post.data.slug}`}
                    color={post.data.color}
                    date={new Date(post.data.date).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}
                  />
                ))}
              </div>

            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <Footer />

</Base>

<style>
.blog-count {
  color: var(--gray);
  font-size: 1.2rem;
  font-weight: 450;
  letter-spacing: .14em;
  margin-bottom: 4rem;
  text-transform: uppercase;
}
</style>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('rv--vis'); obs.unobserve(e.target); } });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.rv').forEach((el) => obs.observe(el));
</script>
