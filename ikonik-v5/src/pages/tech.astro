---
// tech.astro — Pôle Tech IKONIK
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { supabase } from '../lib/supabase';

const CDN = 'https://d3aq9k5clbjrty.cloudfront.net';

let services: { title: string; description: string; tag?: string }[] = [];
try {
  const { data } = await supabase
    .from('services')
    .select('title, description')
    .eq('category', 'tech')
    .order('id');
  if (data && data.length > 0) {
    services = data.map((s: any) => {
      let tag = 'Développement';
      if (s.title.includes('Marketing') || s.title.includes('Automatisation') || s.title.includes('Systèmes') || s.title.includes('croissance')) tag = 'Automatisation';
      return { ...s, tag };
    });
  }
} catch (_) {}

// Fallback statique avec textes validés par Johann
if (services.length === 0) {
  services = [
    { tag: 'Développement', title: 'Sites web & Landing pages', description: "Sites vitrine premium, landing pages optimisées pour la conversion, expériences web immersives. Pensés pour performer dès la mise en ligne." },
    { tag: 'Développement', title: 'Plateformes SaaS', description: "Applications métiers complètes — authentification, paiement, gestion utilisateurs. Architecturées pour scaler avec votre business." },
    { tag: 'Développement', title: 'CRM & Outils métiers', description: "CRM sur mesure, dashboards intelligents, outils de gestion adaptés à votre secteur. Vos données deviennent des décisions." },
    { tag: 'Automatisation', title: 'Marketing OS', description: "Votre système marketing centralisé. Acquisition, campagnes, reporting multi-points de vente — tout dans une seule plateforme." },
    { tag: 'Automatisation', title: 'Automatisation & IA', description: "Workflows automatisés, assistants IA, intégrations API. On connecte vos outils et on élimine les tâches sans valeur ajoutée." },
    { tag: 'Automatisation', title: 'Systèmes de croissance', description: "Tunnels d'acquisition, email marketing, nurturing automatisé. Des systèmes qui génèrent du revenu pendant que vous dormez." },
  ];
}
---

<Base title="Tech — IKONIK" description="Sites web, plateformes SaaS, CRM, Marketing OS, automatisation et systèmes de croissance. L'IA intégrée à chaque étape par IKONIK.">

  <Header />

  <div class="layout layout--dark">
    <div class="layout__inner">

      <!-- HERO -->
      <section class="page-hero">
        <div class="page-hero__bg" style="background-image:url(/images/hero-tech.webp)"></div>
        <div class="page-hero__inner">
          <div class="container">
            <h1 class="page-hero__title">
              <div class="hero-title">
                <span class="hero-line"><em>Tech</em></span>
                <span class="hero-line">
                  <svg fill="none" viewBox="0 0 200 8" width="160" height="8" style="transform:rotate(180deg)">
                    <path d="M180 4H0" stroke="#FFFFFF"></path>
                    <path d="M200 0h-8v8h8V0Z" fill="#E9540D"></path>
                  </svg>
                  SaaS. IA. Systèmes.
                </span>
              </div>
            </h1>
          </div>
        </div>
        <svg fill="none" viewBox="0 0 12 34" class="scroll-ind" aria-hidden="true">
          <path d="M12 0 6 8.195 0 0h12Z" fill="#E9540D"/>
          <path d="m12 25-6 8.195L0 25h12Z" fill="#FFF"/>
        </svg>
      </section>

      <!-- CONTENU -->
      <div class="layout__content">

        <!-- INTRO -->
        <div class="section t-light s-pad-lg">
          <div class="section__inner">
            <div class="container">
              <div class="grid grid--gap-lg rv" style="direction:rtl">
                <div class="new-card" style="direction:ltr">
                  <video autoplay muted playsinline loop src="/videos/tech.mp4" class="new-card__video"></video>
                </div>
                <div class="cb cb--l" style="direction:ltr">
                  <div class="cb__h">
                    <span class="cb__tag">Pôle Tech</span>
                    <h2>
                      <span class="h-line">
                        <span>IKONIK Tech</span>
                        <svg fill="none" viewBox="0 0 200 12" width="140" height="12">
                          <path d="M179 6H0" stroke="#222931"></path>
                          <path d="m191 0 8.195 6L191 12V0Z" fill="#E9540D"></path>
                        </svg>
                      </span>
                    </h2>
                  </div>
                  <div class="cb__wrap">
                    <p class="cb__t">Des plateformes qui tournent, des systèmes qui convertissent. On construit vos outils métiers sur mesure — du CRM au SaaS — l'IA intégrée à chaque étape de votre chaîne de valeur.</p>
                    <div class="cb__ctas">
                      <a class="button" href="/contact">
                        <span class="btn btn--pri">
                          <span class="bt bt--in">Lancer un projet</span>
                          <span class="bt bt--out" aria-hidden="true">Lancer un projet</span>
                        </span>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- SERVICES -->
        <div class="section t-light s-pb-lg">
          <div class="section__inner">
            <div class="container">
              <h2 class="rv" style="font-size:3.6rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-bottom:6rem">Nos services tech</h2>
              <div class="services-grid">
                {services.map((s) => (
                  <div class="service-card rv">
                    {s.tag && <span class="service-card__tag">{s.tag}</span>}
                    <h3 class="service-card__title">{s.title}</h3>
                    <p class="service-card__desc">{s.description}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- CASE STUDIES -->
        <div class="section t-light s-pad-lg">
          <div class="section__inner">
            <div class="container">
              <div class="rv" style="margin-bottom:8rem">
                <span class="cb__tag" style="display:block;margin-bottom:1.6rem">Études de cas</span>
                <h2 style="font-size:3.6rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase">Ce qu'on <em style="font-family:var(--serif);font-style:italic;text-transform:none">construit</em></h2>
              </div>

              <!-- CASE 1 — Marketing OS réseau 100+ PDV -->
              <div class="case-study rv">
                <div class="case-study__visuals">
                  <img src="/case-tech-1.webp" alt="Marketing OS — Dashboard multi-sites" class="case-study__img" width="800" height="450" loading="lazy" />
                </div>
                <div class="case-study__content">
                  <span class="case-study__cat">Plateforme SaaS · Automatisation</span>
                  <h3 class="case-study__title">Marketing OS pour un réseau de <em>100+ points de vente</em></h3>
                  <p class="case-study__desc">Un réseau de franchises en pleine croissance sans aucun système centralisé. Chaque point de vente communiquait à sa façon, l'IA était utilisée sans cadre, l'image de marque se dégradait.</p>
                  <p class="case-study__desc">Nous avons construit une plateforme multi-tenant à 7 modules : formation vidéo par profil avec certification, hub commande supports avec validation siège, vidéothèque multi-format avec calendrier saisonnier, générateur IA encadré avec prompts pré-approuvés, et production cinématique trimestrielle.</p>
                  <div class="case-study__kpis">
                    <div class="case-study__kpi"><span class="case-study__kpi-value">7</span><span class="case-study__kpi-label">Modules intégrés</span></div>
                    <div class="case-study__kpi"><span class="case-study__kpi-value">100+</span><span class="case-study__kpi-label">Points de vente</span></div>
                    <div class="case-study__kpi"><span class="case-study__kpi-value">4</span><span class="case-study__kpi-label">Niveaux d'accès</span></div>
                  </div>
                  <p class="case-study__arch">Application web full-stack avec rendu hybride, base relationnelle avec Row Level Security, authentification multi-niveaux, hébergement vidéo dédié avec streaming adaptatif, fonctions serverless, notifications email transactionnel.</p>
                </div>
              </div>

              <!-- CASE 2 — Plateforme de formation -->
              <div class="case-study case-study--reverse rv">
                <div class="case-study__visuals">
                  <img src="/case-tech-2.webp" alt="Plateforme de formation — Espace élève" class="case-study__img" width="800" height="450" loading="lazy" />
                </div>
                <div class="case-study__content">
                  <span class="case-study__cat">Plateforme SaaS · Formation</span>
                  <h3 class="case-study__title">Plateforme de formation avec <em>espace élève et paiement intégré</em></h3>
                  <p class="case-study__desc">Un formateur indépendant prisonnier de sa plateforme générique — commissions élevées, personnalisation impossible, données clients inaccessibles, tunnel de conversion rigide.</p>
                  <p class="case-study__desc">Migration complète vers un écosystème sur mesure à zéro commission : site vitrine avec capture de leads, espace élève avec vidéos en streaming adaptatif, paiement intégré (unique ou 3 fois), témoignages dynamiques, séquences email automatisées, pipeline commercial avec scoring.</p>
                  <div class="case-study__kpis">
                    <div class="case-study__kpi"><span class="case-study__kpi-value">0%</span><span class="case-study__kpi-label">Commission plateforme</span></div>
                    <div class="case-study__kpi"><span class="case-study__kpi-value">2</span><span class="case-study__kpi-label">Options de paiement</span></div>
                    <div class="case-study__kpi"><span class="case-study__kpi-value">100%</span><span class="case-study__kpi-label">Données propriétaires</span></div>
                  </div>
                  <p class="case-study__arch">Frontend performant avec rendu serveur, base PostgreSQL avec sécurité par rôles, passerelle de paiement avec webhooks, streaming vidéo adaptatif, fonctions serverless, API email transactionnel et marketing.</p>
                </div>
              </div>

              <!-- CASE 3 — Site premium + back-office salon -->
              <div class="case-study rv">
                <div class="case-study__visuals">
                  <img src="/case-tech-3.webp" alt="Site premium + back-office — Salon de beauté" class="case-study__img" width="800" height="450" loading="lazy" />
                </div>
                <div class="case-study__content">
                  <span class="case-study__cat">Site web · Contenu · Réseaux sociaux</span>
                  <h3 class="case-study__title">Site premium + back-office pour un <em>salon de beauté</em></h3>
                  <p class="case-study__desc">Un salon haut de gamme avec un ancien site qui ne reflétait ni la qualité du service ni l'identité de la marque. Aucun outil de gestion de contenu, zéro stratégie réseaux sociaux.</p>
                  <p class="case-study__desc">Création d'un écosystème digital complet : site sur mesure avec direction artistique premium et animations au scroll, back-office admin à 8 modules, production contenu bi-mensuelle (shootings + contenu IA événementiel), stratégie Instagram.</p>
                  <div class="case-study__kpis">
                    <div class="case-study__kpi"><span class="case-study__kpi-value">8</span><span class="case-study__kpi-label">Modules admin</span></div>
                    <div class="case-study__kpi"><span class="case-study__kpi-value">6</span><span class="case-study__kpi-label">Profils équipe</span></div>
                    <div class="case-study__kpi"><span class="case-study__kpi-value">2x</span><span class="case-study__kpi-label">Shootings / mois</span></div>
                  </div>
                  <p class="case-study__arch">Générateur de site statique avec composants interactifs, base de données avec 8 tables et Row Level Security, stockage média avec conversion automatique, analytics intégrés sans cookies tiers, déploiement continu.</p>
                </div>
              </div>

              <!-- CASE 4 — SaaS marque blanche finance -->
              <div class="case-study case-study--reverse rv">
                <div class="case-study__visuals">
                  <img src="/case-tech-4.webp" alt="SaaS marque blanche — Finance" class="case-study__img" width="800" height="450" loading="lazy" />
                </div>
                <div class="case-study__content">
                  <span class="case-study__cat">SaaS · Application métier</span>
                  <h3 class="case-study__title">SaaS marque blanche pour <em>professionnels de la finance</em></h3>
                  <p class="case-study__desc">Des cabinets de gestion de patrimoine avec des outils génériques — aucune vue consolidée, pas de personnalisation à l'image du cabinet, expérience client fragmentée.</p>
                  <p class="case-study__desc">Un SaaS marque blanche industrialisé, déployable pour chaque cabinet : 4 thèmes personnalisables, tableaux de bord interactifs avec visualisation patrimoniale temps réel, arbres de détention, répartition par classe d'actifs. 46 versions itérées avec retours terrain.</p>
                  <div class="case-study__kpis">
                    <div class="case-study__kpi"><span class="case-study__kpi-value">4</span><span class="case-study__kpi-label">Thèmes marque blanche</span></div>
                    <div class="case-study__kpi"><span class="case-study__kpi-value">46</span><span class="case-study__kpi-label">Versions itérées</span></div>
                    <div class="case-study__kpi"><span class="case-study__kpi-value">∞</span><span class="case-study__kpi-label">Instances déployables</span></div>
                  </div>
                  <p class="case-study__arch">Single Page Application avec state management centralisé, bibliothèque de graphiques interactifs, base de données avec isolation par tenant, système de thèmes dynamique, déploiement multi-instances sur CDN.</p>
                </div>
              </div>

              <!-- CASE 5 — CRM métier + site vitrine -->
              <div class="case-study rv">
                <div class="case-study__visuals">
                  <img src="/case-tech-5.webp" alt="CRM métier + site vitrine — Transaction" class="case-study__img" width="800" height="450" loading="lazy" />
                </div>
                <div class="case-study__content">
                  <span class="case-study__cat">CRM sur mesure · Site web · Intelligence données</span>
                  <h3 class="case-study__title">CRM métier + site vitrine pour un <em>cabinet de transaction sectoriel</em></h3>
                  <p class="case-study__desc">Un cabinet de transaction gérait ses mandats sur tableur. Aucune cartographie, aucun pipeline structuré, aucune intelligence sur les données. Les agents terrain n'avaient aucun outil mobile.</p>
                  <p class="case-study__desc">Écosystème complet en 2 applications : site vitrine luxe avec accès gated + CRM à 10 modules — dashboard KPI temps réel, pipeline Kanban, cartographie interactive avec clustering, import intelligent avec enrichissement via APIs gouvernementales, création terrain mobile avec capture photo et géolocalisation, génération de documents en 1 clic.</p>
                  <div class="case-study__kpis">
                    <div class="case-study__kpi"><span class="case-study__kpi-value">10</span><span class="case-study__kpi-label">Modules CRM</span></div>
                    <div class="case-study__kpi"><span class="case-study__kpi-value">2</span><span class="case-study__kpi-label">Applications liées</span></div>
                    <div class="case-study__kpi"><span class="case-study__kpi-value">1 clic</span><span class="case-study__kpi-label">Génération PDF</span></div>
                  </div>
                  <p class="case-study__arch">Frontend composants atomiques, base relationnelle avec Row Level Security sur toutes les tables, cartographie vectorielle, tables de données avec tri/filtres/pagination côté client, drag & drop Kanban, génération PDF côté serveur, import et enrichissement serverless.</p>
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- CTA DARK -->
        <div class="section t-dark s-pad-md">
          <div class="section__inner">
            <div class="container rv" style="text-align:center;color:#fff">
              <p style="font-size:1.2rem;font-weight:450;letter-spacing:.16em;text-transform:uppercase;margin-bottom:2rem">Votre projet tech</p>
              <h2 style="font-size:3.6rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;max-width:800px;margin:0 auto 3rem">Construisons votre avantage concurrentiel</h2>
              <a class="button" href="/contact">
                <span class="btn btn--sec">
                  <span class="bt bt--in">Parler de votre projet</span>
                  <span class="bt bt--out" aria-hidden="true">Parler de votre projet</span>
                </span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <Footer />

</Base>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('rv--vis'); obs.unobserve(e.target); } });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.rv').forEach((el) => obs.observe(el));
</script>
