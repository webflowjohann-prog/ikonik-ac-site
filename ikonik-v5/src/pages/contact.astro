---
// contact.astro — IKONIK OS · Page Contact avec formulaire intelligent
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Contact — Parlons de votre projet | IKONIK" description="Contactez IKONIK pour discuter de votre projet vidéo, développement web ou automatisation. Studio créatif et tech basé en Normandie, France.">
  <Header />
  <div class="layout layout--dark">
    <div class="layout__inner">
      <section class="page-hero">
        <div class="page-hero__bg" style="background-image:url(/images/hero-studio.webp)"></div>
        <div class="page-hero__inner">
          <div class="container">
            <h1 class="page-hero__title">
              <div class="hero-title">
                <span class="hero-line">Parlons de</span>
                <span class="hero-line">
                  <em>votre projet</em>
                  <svg fill="none" viewBox="0 0 200 11" width="160" height="11">
                    <path d="M177 5.5H0" stroke="#FFFFFF"></path>
                    <circle cx="194.5" cy="5.5" r="5.5" fill="#E9540D"></circle>
                  </svg>
                </span>
              </div>
            </h1>
          </div>
        </div>
      </section>

      <div class="layout__content">
        <div class="section t-light s-pad-lg">
          <div class="section__inner">
            <div class="container">
              <div class="contact-layout rv">
                <div class="contact-form-wrap">
                  <span class="cb__tag" style="display:block;margin-bottom:1.6rem">Contact</span>
                  <h2 class="contact-heading">Décrivez votre <em>projet</em></h2>
                  <p class="contact-sub">On revient vers vous sous 24h avec une première analyse.</p>

                  <form id="contact-form" class="contact-form">
                    <div class="form-row">
                      <div class="form-group"><label for="prenom">Prénom</label><input type="text" id="prenom" name="prenom" required placeholder="Votre prénom" /></div>
                      <div class="form-group"><label for="nom">Nom</label><input type="text" id="nom" name="nom" required placeholder="Votre nom" /></div>
                    </div>
                    <div class="form-row">
                      <div class="form-group"><label for="email">Email</label><input type="email" id="email" name="email" required placeholder="vous@entreprise.com" /></div>
                      <div class="form-group"><label for="telephone">Téléphone</label><input type="tel" id="telephone" name="telephone" placeholder="+33 6 00 00 00 00" /></div>
                    </div>
                    <div class="form-group"><label for="entreprise">Entreprise</label><input type="text" id="entreprise" name="entreprise" placeholder="Nom de votre entreprise" /></div>

                    <div class="form-group">
                      <label>Type de projet</label>
                      <div class="radio-group">
                        <label class="radio-card"><input type="radio" name="type_projet" value="creatif" /><span class="radio-card__inner"><span class="radio-card__title">Créatif</span><span class="radio-card__desc">Film, animation, contenu</span></span></label>
                        <label class="radio-card"><input type="radio" name="type_projet" value="tech" /><span class="radio-card__inner"><span class="radio-card__title">Tech</span><span class="radio-card__desc">Site, SaaS, CRM, IA</span></span></label>
                        <label class="radio-card"><input type="radio" name="type_projet" value="les-deux" checked /><span class="radio-card__inner"><span class="radio-card__title">Les deux</span><span class="radio-card__desc">Créatif + Tech</span></span></label>
                      </div>
                    </div>

                    <div class="form-group">
                      <label>Budget estimé</label>
                      <div class="radio-group radio-group--budget">
                        <label class="radio-pill"><input type="radio" name="budget" value="moins-5k" /><span>&lt; 5K€</span></label>
                        <label class="radio-pill"><input type="radio" name="budget" value="5k-15k" /><span>5K — 15K€</span></label>
                        <label class="radio-pill"><input type="radio" name="budget" value="15k-50k" /><span>15K — 50K€</span></label>
                        <label class="radio-pill"><input type="radio" name="budget" value="plus-50k" /><span>50K€+</span></label>
                        <label class="radio-pill"><input type="radio" name="budget" value="non-precise" checked /><span>À définir</span></label>
                      </div>
                    </div>

                    <div class="form-group"><label for="message">Votre projet</label><textarea id="message" name="message" rows="5" placeholder="Décrivez votre projet, vos objectifs, votre calendrier..."></textarea></div>

                    <button type="submit" class="form-submit" id="submit-btn">
                      <span class="form-submit__text">Envoyer ma demande</span>
                      <span class="form-submit__loading" style="display:none">Envoi en cours...</span>
                    </button>

                    <div id="form-success" class="form-success" style="display:none">
                      <div class="form-success__icon">✓</div>
                      <h3>Message envoyé</h3>
                      <p>Nous revenons vers vous sous 24h avec une première analyse de votre projet.</p>
                    </div>
                    <div id="form-error" class="form-error" style="display:none">
                      <p>Une erreur est survenue. Contactez-nous à <a href="mailto:contact@ikonik-ac.com">contact@ikonik-ac.com</a></p>
                    </div>
                  </form>
                </div>

                <div class="contact-info">
                  <div class="info-card rv"><h3 class="info-card__title">IKONIK</h3><p class="info-card__text">Studio créatif & tech</p><p class="info-card__text">Normandie, France</p></div>
                  <div class="info-card rv"><h3 class="info-card__title">Email</h3><a href="mailto:contact@ikonik-ac.com" class="info-card__link">contact@ikonik-ac.com</a></div>
                  <div class="info-card rv"><h3 class="info-card__title">Téléphone</h3><a href="tel:+33660657056" class="info-card__link">+33 6 60 65 70 56</a></div>
                  <div class="info-card rv"><h3 class="info-card__title">Réseaux</h3><div class="info-card__socials"><a href="https://www.instagram.com/ikonik_artisan_creatif/" target="_blank" rel="noopener">Instagram</a><a href="https://www.linkedin.com/in/%E2%9C%85-johann-langenberg-production-video/" target="_blank" rel="noopener">LinkedIn</a></div></div>
                  <div class="info-card info-card--accent rv"><p class="info-card__quote">"Je prends 2 projets de cette envergure par mois. Le calendrier a une fenêtre."</p><p class="info-card__author">— Johann, Fondateur</p></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- NEWSLETTER -->
        <div class="section t-dark s-pad-md">
          <div class="section__inner">
            <div class="container rv" style="text-align:center;color:#fff;max-width:600px;margin:0 auto">
              <p style="font-size:1.2rem;font-weight:450;letter-spacing:.16em;text-transform:uppercase;margin-bottom:2rem">Newsletter</p>
              <h2 style="font-size:2.8rem;font-weight:600;letter-spacing:.06em;margin-bottom:1.6rem">Restez connecté</h2>
              <p style="color:var(--gray);font-size:1.5rem;margin-bottom:3rem">Recevez nos analyses et retours d'expérience. Pas de spam — du contenu qui compte.</p>
              <form id="newsletter-form" style="display:flex;gap:1.2rem;max-width:480px;margin:0 auto">
                <input type="email" id="nl-email" required placeholder="votre@email.com" style="flex:1;padding:1.4rem 2rem;border-radius:12px;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.06);color:#fff;font-size:1.5rem;font-family:var(--sans);outline:none" />
                <button type="submit" style="padding:1.4rem 2.8rem;border-radius:12px;border:none;background:var(--accent);color:#fff;font-size:1.4rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;white-space:nowrap">S'inscrire</button>
              </form>
              <p id="nl-success" style="display:none;color:#4BB2F2;margin-top:1.6rem;font-size:1.4rem">Inscription confirmée. Bienvenue.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
  <Footer />
</Base>

<style>
.contact-layout{display:grid;gap:6rem;grid-template-columns:1fr}
@media(min-width:992px){.contact-layout{grid-template-columns:1.4fr 1fr;gap:8rem}}
.contact-heading{font-family:var(--sans);font-size:3.2rem;font-weight:600;letter-spacing:.04em;line-height:4rem;margin:0 0 1.2rem}
.contact-heading em{font-family:var(--serif);font-style:italic;font-weight:400}
.contact-sub{color:var(--gray);font-size:1.5rem;line-height:2.4rem;margin:0 0 4rem}
.form-row{display:grid;gap:2rem;grid-template-columns:1fr 1fr}
@media(max-width:600px){.form-row{grid-template-columns:1fr}}
.form-group{margin-bottom:2.4rem}
.form-group label{color:var(--text);display:block;font-size:1.2rem;font-weight:500;letter-spacing:.1em;margin-bottom:.8rem;text-transform:uppercase}
.form-group input,.form-group textarea{background:rgba(0,0,0,.03);border:1px solid rgba(0,0,0,.1);border-radius:12px;color:var(--text);font-family:var(--sans);font-size:1.5rem;padding:1.4rem 2rem;transition:border-color .3s,box-shadow .3s;width:100%}
.form-group input:focus,.form-group textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(233,84,13,.1);outline:none}
.form-group textarea{resize:vertical}
.radio-group{display:grid;gap:1.2rem;grid-template-columns:repeat(3,1fr)}
@media(max-width:600px){.radio-group{grid-template-columns:1fr}}
.radio-card{cursor:pointer}
.radio-card input{display:none}
.radio-card__inner{background:rgba(0,0,0,.03);border:1px solid rgba(0,0,0,.1);border-radius:12px;display:block;padding:1.6rem;text-align:center;transition:border-color .3s,background .3s}
.radio-card input:checked+.radio-card__inner{background:rgba(233,84,13,.06);border-color:var(--accent)}
.radio-card__title{color:var(--text);display:block;font-size:1.5rem;font-weight:600;margin-bottom:.4rem}
.radio-card__desc{color:var(--gray);display:block;font-size:1.2rem}
.radio-group--budget{display:flex;flex-wrap:wrap;gap:.8rem;grid-template-columns:unset}
.radio-pill{cursor:pointer}
.radio-pill input{display:none}
.radio-pill span{background:rgba(0,0,0,.03);border:1px solid rgba(0,0,0,.1);border-radius:40px;color:var(--gray);display:inline-block;font-size:1.3rem;padding:.8rem 1.8rem;transition:all .3s}
.radio-pill input:checked+span{background:rgba(233,84,13,.06);border-color:var(--accent);color:var(--accent);font-weight:500}
.form-submit{background:var(--accent);border:none;border-radius:12px;color:#fff;cursor:pointer;font-family:var(--sans);font-size:1.5rem;font-weight:600;letter-spacing:.08em;margin-top:1rem;padding:1.6rem 4rem;text-transform:uppercase;transition:background .3s,transform .2s;width:100%}
.form-submit:hover{background:#d04a0b}
.form-submit:active{transform:scale(.98)}
.form-submit:disabled{cursor:wait;opacity:.7}
.form-success{background:rgba(75,178,242,.08);border:1px solid rgba(75,178,242,.3);border-radius:16px;margin-top:2rem;padding:3rem;text-align:center}
.form-success__icon{background:#4BB2F2;border-radius:50%;color:#fff;display:inline-flex;align-items:center;justify-content:center;font-size:2rem;height:48px;margin-bottom:1.6rem;width:48px}
.form-success h3{font-size:2rem;margin:0 0 .8rem}
.form-success p{color:var(--gray);font-size:1.4rem;margin:0}
.form-error{background:rgba(233,84,13,.08);border:1px solid rgba(233,84,13,.3);border-radius:12px;margin-top:2rem;padding:1.6rem 2rem}
.form-error p{color:var(--accent);font-size:1.4rem;margin:0}
.form-error a{color:var(--accent)}
.contact-info{display:flex;flex-direction:column;gap:2.4rem}
.info-card{border-bottom:1px solid rgba(0,0,0,.06);padding-bottom:2.4rem}
.info-card:last-child{border-bottom:none}
.info-card__title{color:var(--text);font-size:1.2rem;font-weight:500;letter-spacing:.14em;margin:0 0 .8rem;text-transform:uppercase}
.info-card__text{color:var(--gray);font-size:1.5rem;line-height:2.4rem;margin:0}
.info-card__link{color:var(--text);font-size:1.5rem;text-decoration:none;transition:color .3s}
.info-card__link:hover{color:var(--accent)}
.info-card__socials{display:flex;gap:2rem}
.info-card__socials a{color:var(--text);font-size:1.5rem;text-decoration:none;transition:color .3s}
.info-card__socials a:hover{color:var(--accent)}
.info-card--accent{background:rgba(0,0,0,.03);border:none;border-radius:16px;padding:3rem}
.info-card__quote{color:var(--text);font-family:var(--serif);font-size:1.8rem;font-style:italic;line-height:2.8rem;margin:0 0 1.2rem}
.info-card__author{color:var(--accent);font-size:1.2rem;font-weight:500;letter-spacing:.1em;margin:0;text-transform:uppercase}
</style>

<script is:inline>
var SB='https://kgfolduvslsytbekbjvf.supabase.co';
var SK='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtnZm9sZHV2c2xzeXRiZWtianZmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUxNDU3MDcsImV4cCI6MjA5MDcyMTcwN30.4jZ9fMfSinEc1CE3s6LuR4q_WNeisEdtyBM5XQ2uMJg';
var H={'Content-Type':'application/json','apikey':SK,'Authorization':'Bearer '+SK,'Prefer':'return=minimal'};

document.getElementById('contact-form').addEventListener('submit',async function(e){
  e.preventDefault();
  var b=document.getElementById('submit-btn');
  b.disabled=true;
  b.querySelector('.form-submit__text').style.display='none';
  b.querySelector('.form-submit__loading').style.display='inline';
  try{
    var r=await fetch(SB+'/rest/v1/contacts',{method:'POST',headers:H,body:JSON.stringify({
      prenom:document.getElementById('prenom').value,
      nom:document.getElementById('nom').value,
      email:document.getElementById('email').value,
      telephone:document.getElementById('telephone').value||null,
      entreprise:document.getElementById('entreprise').value||null,
      type_projet:document.querySelector('input[name="type_projet"]:checked')?.value||'les-deux',
      budget:document.querySelector('input[name="budget"]:checked')?.value||'non-precise',
      message:document.getElementById('message').value||null,
      source:'site-contact',page_origine:window.location.pathname
    })});
    if(r.ok){document.getElementById('contact-form').style.display='none';document.getElementById('form-success').style.display='block';
        if(window.ikonikTrack)window.ikonikTrack('lead_created',{description:'Contact form submitted',type_projet:data.type_projet,budget:data.budget,email_hash:btoa(data.email)})}
    else throw new Error()
  }catch(err){document.getElementById('form-error').style.display='block';b.disabled=false;b.querySelector('.form-submit__text').style.display='inline';b.querySelector('.form-submit__loading').style.display='none'}
});

document.getElementById('newsletter-form').addEventListener('submit',async function(e){
  e.preventDefault();
  try{await fetch(SB+'/rest/v1/newsletter_subscribers',{method:'POST',headers:H,body:JSON.stringify({email:document.getElementById('nl-email').value,source:'site-newsletter'})});
  document.getElementById('newsletter-form').style.display='none';document.getElementById('nl-success').style.display='block';
  if(window.ikonikTrack)window.ikonikTrack('newsletter_signup',{description:'Newsletter subscription',email_hash:btoa(email)})}catch(err){}
});
</script>
<script>
  const obs=new IntersectionObserver((e)=>{e.forEach((e)=>{if(e.isIntersecting){e.target.classList.add('rv--vis');obs.unobserve(e.target)}})},{threshold:.1,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.rv').forEach((el)=>obs.observe(el));
</script>
